{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "git-kb daemon status --quiet >/dev/null 2>&1 || git-kb daemon start --background >/dev/null 2>&1",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "vox -l fr \"Terminé.\"",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "outputStyle": "Proactive",
  "permissions": {
    "allow": [
      "Bash(rtk *)",
      "Bash(rtk grep *)",
      "Bash(rtk git *)",
      "Bash(cd *)",
      "Bash(git add *)",
      "Bash(git checkout *)",
      "Bash(git commit *)",
      "Skill(update-config)",
      "Bash(icm *)",
      "Bash(yazelix *)",
      "Bash(yzx *)",
      "Bash(grit *)",
      "Bash(gitnexus *)",
      "Bash(weave *)",
      "Bash(gitkb *)",
      "Bash(git kb *)",
      "Bash(ruflo *)",
      "Bash(prompt_hub *)",
      "Bash(prompt-hub *)",
      "Bash(omc *)",
      "Bash(nu_plugin *)",
      "Bash(teri *)",
      "Bash(rusty-idd *)",
      "Bash(handoff *)",
      "Bash(meta *)",
      "Bash(envctl *)",
      "Bash(beads *)",
      "Bash(br *)",
      "Bash(atc *)",
      "Bash(vox *)",
      "mcp__icm",
      "mcp__icm__*"
    ]
  }
}