{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "echo \"[ubuntu-lifeos] Mandate: Boil the Ocean (Garry Tan) \u2014 completeness on the asked-for scope is the target. Style: Karpathy guidelines \u2014 think before coding, simplicity first, surgical changes, goal-driven execution. Authority: ./CLAUDE.md + ./AGENTS.md (top-of-file). Full Karpathy spec: andrej-karpathy-skills:karpathy-guidelines.\"",
            "timeout": 2000,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "sh -lc 'root=\"$(git rev-parse --show-toplevel)\"; exec rusty-idd next --base \"$root\"'",
            "statusMessage": "Rusty IDD front door: computing the next step",
            "timeout": 180,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.handoff/hooks/loop-entry.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "node /home/drdave/repos/ubuntu-lifeos/.claude/hooks/session-log.mjs",
            "timeout": 3000,
            "type": "command"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.handoff/hooks/session-end.sh\""
          }
        ]
      }
    ]
  }
}
