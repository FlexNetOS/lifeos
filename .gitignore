# Dependencies (lockfile IS committed — bun is the team standard)
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build outputs
dist/
dist-ssr/
*.local

# Vite cache
.vite/

# Rust / Tauri
src-tauri/target/
src-tauri/gen/schemas
target/
firmware/esp32/target/

# OMC volatile state — session-local, regenerated on each run
.omc/state/
.omc/logs/
.omc/sessions/

# .claude — commit shared agent config; ignore local/session/worktree state.
# Canonical target: envctl generates .claude from PostgreSQL/RuVector per worktree
# (blueprint hard rule 14 + §4.7); until then git carries the shared pieces.
#   Committed (shared, every worktree needs it): settings.json, skills/, rules/, hooks/
#   Ignored (local / session / machine-specific):
.claude/settings.local.json
.claude/projects/
.claude/worktrees/
.claude/**/*.local.json

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.swp
*.swo
*~

# Test coverage
coverage/

# Python/runtime transients
__pycache__/
*.py[cod]
*.pid
.pytest_cache/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# handoff continuity: binary ledger cache + migration artifacts are gitignored
# (committed truth = .handoff/ledger.events.jsonl — ADR-0018 D1 / HFTASK-0067)
.handoff/**/ledger.db
.handoff/**/*.db-wal
.handoff/**/*.db-shm
.handoff/**/*.rvf
.handoff/**/*.rvf.lock
.handoff/**/*.sqlite.bak
.handoff/**/*.redb.tmp

# GitKB
.kb/.cache/
.kb/workspace/
.kb/workspaces/

.grit
