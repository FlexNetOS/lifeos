{
  "name": "lifeos-vue",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "description": "LifeOS — Vue 3 + Tauri UI kit (Path B). Sibling of ui_kits/lifeos_app/ React canon.",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "planning-spine:navigation:generate": "bun planning-spine-v0/scripts/build-navigation-index.mjs --write",
    "planning-spine:navigation:check": "bun planning-spine-v0/scripts/build-navigation-index.mjs --check",
    "planning-spine:navigation:query": "bun planning-spine-v0/scripts/build-navigation-index.mjs --query",
    "planning-spine:navigation:explain": "bun planning-spine-v0/scripts/build-navigation-index.mjs --explain",
    "planning-spine:verify": "bun scripts/verify-planning-spine.mjs",
    "verify:nbverify004:claim001": "bun scripts/verify-nbverify004-claim001.mjs",
    "verify:nbverify004:claim002": "bun scripts/verify-nbverify004-claim002.mjs",
    "verify:nbverify004:claims003-004": "bun scripts/verify-nbverify004-claims003-004.mjs",
    "verify:nbverify004:claim005": "bun scripts/verify-nbverify004-claim005.mjs",
    "verify:nbverify004:claim006": "bun scripts/verify-nbverify004-claim006.mjs",
    "verify:nbverify004:claim007": "bun scripts/verify-nbverify004-claim007.mjs",
    "verify:nbverify004:claim008": "bun scripts/verify-nbverify004-claim008.mjs",
    "verify:nbverify004:claim009": "bun scripts/verify-nbverify004-claim009.mjs",
    "verify:nbverify004:claim010": "bun scripts/verify-nbverify004-claim010.mjs",
    "verify:nbverify004:claim011": "bun scripts/verify-nbverify004-claim011.mjs",
    "verify:nbverify004:claim012": "bun scripts/verify-nbverify004-claim012.mjs",
    "verify:nbverify004:claim013": "bun scripts/verify-nbverify004-claim013.mjs",
    "verify:nbverify004:claim014": "bun scripts/verify-nbverify004-claim014.mjs",
    "verify:nbverify004:progress": "bun scripts/verify-nbverify004-progress.mjs",
    "verify:nbverify004:claims005-007": "bun scripts/verify-nbverify004-claims005-007.mjs",
    "test:node-authority": "bunx --no-install --bun vitest run tests/node-authority-install.spec.ts",
    "verify:node-authority": "bun scripts/verify-node-authority.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:icons": "bunx --no-install --bun tauri icon public/lifeos-app-icon.png && python3 scripts/canonicalize-icns.py src-tauri/icons/icon.icns",
    "tauri:icons:check": "python3 scripts/canonicalize-icns.py --check src-tauri/icons/icon.icns",
    "design:lint": "design.md lint DESIGN.md",
    "design:diff": "node scripts/design-diff.mjs",
    "design:export:dtcg": "design.md export --format dtcg DESIGN.md > design-system-reference/exports/tokens.json",
    "design:export:tailwind": "design.md export --format tailwind DESIGN.md > design-system-reference/exports/tailwind.theme.json",
    "design:export": "bun run design:export:dtcg && bun run design:export:tailwind",
    "test:a11y": "vitest run --config vitest.a11y.config.ts",
    "check": "vue-tsc --noEmit && bun run test && bun run test:a11y && bun run design:lint && bun run tauri:icons:check"
  },
  "dependencies": {
    "@lucide/vue": "^1.16.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@google/design.md": "0.1.1",
    "@ruvector/ruvllm": "2.6.0",
    "@ruvector/rvf": "0.2.3",
    "@ruvector/sona": "0.1.7",
    "@ruvector/tiny-dancer": "0.1.22",
    "@tauri-apps/cli": "^2.11.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/test-utils": "^2.4.10",
    "agentdb": "3.0.0-alpha.17",
    "ajv": "^8.20.0",
    "axe-core": "^4.11.4",
    "esbuild": "^0.28.0",
    "happy-dom": "^20.9.0",
    "ruvector": "0.2.34",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "vitest-axe": "^0.1.0",
    "vue-tsc": "^3.3.1",
    "yaml": "^2.8.1"
  },
  "trustedDependencies": [
    "agentdb",
    "protobufjs"
  ]
}
