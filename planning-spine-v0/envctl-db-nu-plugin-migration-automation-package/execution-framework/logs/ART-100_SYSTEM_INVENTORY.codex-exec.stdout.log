+    "var/tmp/",
+)
+SKIP_REL_PARTS = {"_work", ".worktrees", "release/out", "vendor"}
+TEXT_EXTENSIONS = {
+    ".conf",
+    ".go",
+    ".json",
+    ".kdl",
+    ".md",
+    ".nix",
+    ".nu",
+    ".py",
+    ".rs",
