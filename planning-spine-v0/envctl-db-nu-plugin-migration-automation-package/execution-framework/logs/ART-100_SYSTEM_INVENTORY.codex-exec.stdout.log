+SCRIPT_SUFFIXES = {".bash", ".fish", ".nu", ".pl", ".ps1", ".py", ".rb", ".sh", ".zsh"}
+MAX_CONTENT_BYTES = 256 * 1024
+MAX_ITEMS_PER_CATEGORY = 200
+MAX_MARKDOWN_ROWS = 40
