+
+def parse_go_mod(path: Path) -> str:
+    try:
+        for line in path.read_text(encoding="utf-8", errors="ignore").splitlines():
+            if line.startswith("module "):
+                return line.split(None, 1)[1].strip()
+    except OSError:
