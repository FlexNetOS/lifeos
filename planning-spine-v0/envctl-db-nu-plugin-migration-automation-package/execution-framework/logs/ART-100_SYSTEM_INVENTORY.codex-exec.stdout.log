+    if suffix == ".service":
+        add_item(categories, totals, "services", make_item("systemd_service", path, target_root, **parse_systemd_unit(path)))
+    if name in {"docker-compose.yml", "docker-compose.yaml", "compose.yml", "compose.yaml"}:
