+
+def parse_systemd_unit(path: Path) -> dict[str, str]:
+    out: dict[str, str] = {}
+    for line in read_text_limited(path).splitlines():
+        if "=" not in line:
+            continue
+        key, value = line.split("=", 1)
+        if key in {"Description", "ExecStart", "WantedBy", "OnCalendar", "Unit"}:
+            out[key.lower()] = value.strip()
