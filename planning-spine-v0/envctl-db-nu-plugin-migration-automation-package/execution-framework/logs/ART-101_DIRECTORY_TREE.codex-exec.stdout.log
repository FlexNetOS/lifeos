+CODE_SUFFIXES = {
+    ".rs",
+    ".py",
+    ".nu",
+    ".sh",
+    ".bash",
+    ".zsh",
+    ".js",
+    ".jsx",
+    ".ts",
+    ".tsx",
+    ".go",
