+    ".h",
+    ".cpp",
+    ".hpp",
+    ".lua",
+    ".vim",
+}
+CONFIG_SUFFIXES = {
+    ".toml",
+    ".yaml",
+    ".yml",
+    ".json",
+    ".jsonnet",
