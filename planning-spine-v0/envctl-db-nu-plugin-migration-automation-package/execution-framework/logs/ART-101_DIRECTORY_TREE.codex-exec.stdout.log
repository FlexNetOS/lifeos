+        tags.add("data")
+    if name in BUILD_MARKERS or parts & {"nix", "packaging", "build", "ci"}:
+        tags.add("build")
+    if any(marker in parts or marker in name for marker in TEST_MARKERS):
+        tags.add("test")
+    if suffix in {".md", ".rst", ".txt"} or parts & {"docs", "doc", "prompts"}:
+        tags.add("docs")
+    return tags or {"other"}
