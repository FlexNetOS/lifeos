+DATA_SUFFIXES = {".sql", ".csv", ".tsv", ".jsonl", ".db", ".sqlite", ".parquet"}
+TEST_MARKERS = ("test", "tests", "spec", "specs", "fixture", "fixtures", "validation")
+BUILD_MARKERS = ("cargo.toml", "flake.nix", "makefile", "package.json", "pyproject.toml", "justfile")
