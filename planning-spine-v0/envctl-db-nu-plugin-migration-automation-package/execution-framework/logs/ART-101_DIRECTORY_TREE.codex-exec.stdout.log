+TARGET_ID = "target-art101-flexnetos"
+RECIPE_ID = "recipe-art101-directory-tree"
+OPERATION_ID = "op-art101-generate-register"
+CONTRACT_ID = "contract-full-migration-artifact-contract-1.0.0"
