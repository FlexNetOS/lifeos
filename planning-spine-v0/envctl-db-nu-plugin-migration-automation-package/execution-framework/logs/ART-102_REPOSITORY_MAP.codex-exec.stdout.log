+        "execution-framework/proof_records/ART-102_REPOSITORY_MAP.proof.json",
+        "execution-framework/proof_records/proof_ledger.jsonl",
+    ]
+    proof = make_proof(
+        TASK_ID,
+        "completed" if verification["status"] == "passed" else "failed",
+        "codex-cli-local",
+        HELPER_ID,
+        MODEL_TAG,
+        str(package_root()),
+        files_changed,
