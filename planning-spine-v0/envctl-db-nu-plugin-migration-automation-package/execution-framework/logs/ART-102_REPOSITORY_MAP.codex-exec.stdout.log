+    lines.extend(["", "## Language Rollup", "", "| Language | Files |", "| --- | ---: |"])
+    for language, count in report["summary"]["language_file_rollup"].items():
+        lines.append(f"| {language} | {count} |")
+    lines.extend(
+        [
+            "",
+            "## Repositories",
+            "",
+            "| Path | Scope | Branch | Head | Files | Dirty | Owners | Markers | Last activity |",
+            "| --- | --- | --- | --- | ---: | ---: | --- | --- | --- |",
