+    ".venv",
+    "__pycache__",
+    "node_modules",
+    "target",
+}
+BLOCKED_SUFFIXES = (".pem", ".key")
+BLOCKED_PARTS = {".env", "secrets", "private_keys"}
+LANGUAGE_EXTENSIONS = {
+    ".rs": "Rust",
+    ".py": "Python",
+    ".nu": "Nushell",
+    ".nix": "Nix",
+    ".toml": "TOML",
+    ".json": "JSON",
