    {
        "task_id": TASK_ID,
        "status": "complete",
        "updated_at": now(),
        "artifact": rel("migration-artifacts/art-103_service_dep_graph/service-dependency-graph.json"),
        "proof_uri": "proof_records/ART-103_SERVICE_DEP_GRAPH.proof.json",
        "registered_artifact_count": len(registered),
    },
)

files_changed = [rel(path) for *_rest, path in artifacts] + [
    rel(registry_report_path),
    rel(heartbeat_path),
