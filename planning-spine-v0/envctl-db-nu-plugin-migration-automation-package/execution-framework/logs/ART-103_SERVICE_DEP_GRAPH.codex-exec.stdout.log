STARTED_AT = datetime.now(timezone.utc).replace(microsecond=0).isoformat()
BLOCKED = ('**/.env', '**/secrets/**', '**/private_keys/**', '**/*.pem', '**/*.key')
SKIP_DIRS = {'.git', '.kb', '.cache', 'target', 'node_modules', '__pycache__', '.mypy_cache', '.pytest_cache'}


def now():
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat()


def rel(path: Path, base: Path = ROOT) -> str:
    return str(path.relative_to(base)).replace('\\\\', '/')


def pkg_rel(path: Path) -> str:
    return str(path.relative_to(PACKAGE_ROOT)).replace('\\\\', '/')


def sha256_file(path: Path) -> str:
    h = hashlib.sha256()
    with path.open('rb') as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b''):
            h.update(chunk)
    return 'sha256:' + h.hexdigest()


def is_blocked(path: Path) -> bool:
    text = str(path).replace('\\\\', '/')
    return any(fnmatch.fnmatch(text, pat) or fnmatch.fnmatch('/' + text, pat) for pat in BLOCKED)


def scan_target(root: Path) -> dict:
    service_files = []
    manifests = []
    code_files = []
    docs = []
    interesting_suffixes = {'.service', '.timer', '.socket', '.toml', '.yaml', '.yml', '.nix', '.rs', '.nu', '.sh', '.md', '.json'}
    manifest_names = {'Cargo.toml', 'package.json', 'pyproject.toml', 'flake.nix', '.meta.yaml'}
    for current, dirs, files in os.walk(root):
        dirs[:] = [d for d in dirs if d not in SKIP_DIRS and not is_blocked(Path(current) / d)]
        current_path = Path(current)
        for name in files:
            p = current_path / name
            if is_blocked(p):
                continue
            suffix = p.suffix
            try:
                rp = str(p.relative_to(root)).replace('\\\\', '/')
            except ValueError:
                rp = str(p)
            if suffix in {'.service', '.timer', '.socket'}:
                service_files.append(rp)
            if name in manifest_names or suffix in {'.nix', '.toml', '.yaml', '.yml'}:
                manifests.append(rp)
            if suffix in {'.rs', '.nu', '.sh'}:
                code_files.append(rp)
            if suffix == '.md' and (rp in {'AGENTS.md', 'WORKSPACE_LAYOUT.md', 'LOCAL_WORKAROUNDS.md', 'WORKLOG.md'} or rp.startswith('src/') or rp.startswith('docs/')):
                docs.append(rp)
    return {
        'target_root': str(root),
        'service_definition_count': len(service_files),
        'manifest_count': len(manifests),
        'code_file_count': len(code_files),
        'selected_service_definitions': service_files[:80],
        'selected_manifests': manifests[:120],
        'selected_docs': docs[:80],
        'blocked_patterns': list(BLOCKED),
        'skipped_dirs': sorted(SKIP_DIRS),
    }


def read_json(path: str) -> dict:
    return json.loads((ROOT / path).read_text(encoding='utf-8'))


def task_rows() -> list[dict]:
    data = read_json('generated/task_graph.normalized.json')
