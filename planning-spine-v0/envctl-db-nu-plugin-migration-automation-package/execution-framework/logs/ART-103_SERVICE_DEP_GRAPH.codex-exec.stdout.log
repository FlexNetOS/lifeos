    },
    "artifact_file_exists": all((ROOT / path).is_file() for *_rest, path in artifacts),
    "envctl_artifact_registry_contains_hash": all(item["hash_recorded"] for item in registry_checks),
    "registered_artifact_count": len(registered),
    "registry_checks": registry_checks,
}

registry_report_path = "migration-artifacts/art-103_service_dep_graph/registry-report.json"
write_json(
    registry_report_path,
    {
        "schema_version": "1.0",
        "task_id": TASK_ID,
        "generated_at": now(),
        "verification": verification,
        "registered_artifacts": registered,
    },
)
