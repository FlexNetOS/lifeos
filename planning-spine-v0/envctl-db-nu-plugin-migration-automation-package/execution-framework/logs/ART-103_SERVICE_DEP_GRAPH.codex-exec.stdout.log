]
missing = [path for *_rest, path in artifacts if not (ROOT / path).is_file()]
if missing:
    raise SystemExit(f"missing generated artifact(s): {missing}")

conn = sqlite3.connect(":memory:")
conn.execute("PRAGMA foreign_keys = ON")
seed_fixture(conn)
registry = ArtifactRegistry(conn, PACKAGE_ROOT)
registered = []
for artifact_id, title, artifact_type, path in artifacts:
    registered.append(
        registry.register(
            {
                **common,
                "artifact_id": artifact_id,
                "title": title,
                "artifact_type": artifact_type,
                "path": rel(path),
                "content_hash": f"sha256:{sha256_file(ROOT / path)}",
            }
        )
    )

registry_checks = []
for row in registered:
    fetched = fetch_artifact(conn, row["run_id"], row["artifact_id"])
    registry_checks.append(
        {
            "artifact_id": row["artifact_id"],
            "path": row["path"],
            "content_hash": row["content_hash"],
            "hash_recorded": bool(fetched and fetched.get("content_hash") == row["content_hash"]),
            "validation_ids": row["validation_ids"],
            "graph_edge_ids": row["graph_edge_ids"],
            "evidence_ids": row["evidence_ids"],
        }
    )

verification = {
    "status": "pass",
    "task_id": TASK_ID,
    "target_root": TARGET_ROOT,
    "contract_id": CONTRACT_ID,
    "run_id": RUN_ID,
