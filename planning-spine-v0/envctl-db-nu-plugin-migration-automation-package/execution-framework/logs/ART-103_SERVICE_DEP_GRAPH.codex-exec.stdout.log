        },
    ],
}
artifacts = [
    ("art-103-service-dep-graph-json", "ART-103 Service Dependency Graph JSON", "service_dependency_graph", "migration-artifacts/art-103_service_dep_graph/service-dependency-graph.json"),
    ("art-103-service-dep-graph-md", "ART-103 Service Dependency Graph Markdown", "service_dependency_graph", "migration-artifacts/art-103_service_dep_graph/service-dependency-graph.md"),
    ("01-current-state-dependency-graph-md", "Dependency Graph", "migration_artifact", "migration-artifacts/01-current-state/dependency-graph.md"),
    ("01-current-state-application-service-dependency-graph-md", "Application Service Dependency Graph", "migration_artifact", "migration-artifacts/01-current-state/application-service-dependency-graph.md"),
