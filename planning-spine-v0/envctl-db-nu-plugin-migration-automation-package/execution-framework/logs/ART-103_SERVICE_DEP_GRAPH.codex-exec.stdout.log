from datetime import datetime, timezone
from pathlib import Path

ROOT = Path.cwd()
PACKAGE_ROOT = ROOT.parent
sys.path.insert(0, str(ROOT / \"scripts\"))

from artifact_registry import ArtifactRegistry, fetch_artifact  # type: ignore
from verify_envctl_db_schema import apply_migrations  # type: ignore
from _common import append_proof, make_proof, sha256_file  # type: ignore

TASK_ID = \"ART-103_SERVICE_DEP_GRAPH\"
RUN_ID = \"run-art103-service-dep-graph\"
OPERATION_ID = \"op-art103-generate-register\"
TARGET_ID = \"target-flexnetos-vs-lifeos-art103\"
CONTRACT_ID = \"contract-full-migration-artifact-contract-1.0.0\"
RECIPE_ID = \"recipe-flexnetos-package-artifact-contract-1.0.0\"
TARGET_ROOT = \"/home/flexnetos/FlexNetOS\"
LOG_URI = \"logs/ART-103_SERVICE_DEP_GRAPH.log\"

def now() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat()

def rel(p: str) -> str:
    return f\"execution-framework/{p}\"

def read_json(path: str) -> dict:
    return json.loads((ROOT / path).read_text(encoding=\"utf-8\"))

def write_json(path: str, payload: dict) -> None:
    target = ROOT / path
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(json.dumps(payload, indent=2, sort_keys=False) + \"\\n\", encoding=\"utf-8\")

def seed_fixture(conn: sqlite3.Connection) -> None:
    apply_migrations(conn, PACKAGE_ROOT)
    seed_sql = (ROOT / \"generated\" / \"contract_manifest.seed.sql\").read_text(encoding=\"utf-8\")
    conn.executescript(seed_sql)
    descriptor = read_json(\"generated/envctl_target_registry.json\")
    target = descriptor.get(\"targets\", [{}])[0]
    conn.execute(
        \"\"\"
        INSERT INTO envctl_migration_targets
          (id, target_id, target_type, primary_root, compare_root, descriptor_json,
           descriptor_hash, safety_mode, max_auto_risk)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
        ON CONFLICT(target_id) DO NOTHING
        \"\"\",
        (
            TARGET_ID,
            target.get(\"target_id\", \"flexnetos-vs-lifeos\"),
            target.get(\"target_type\", \"mixed\"),
            target.get(\"primary_root\", TARGET_ROOT),
            target.get(\"compare_root\", \"/home/flexnetos/lifeos\"),
            json.dumps(target, sort_keys=True),
            descriptor.get(\"descriptor_hash\", \"sha256:art103-target-descriptor\"),
            \"approval-gated\",
            \"R2\",
        ),
    )
    conn.execute(
        \"\"\"
        INSERT INTO envctl_migration_runs
          (id, target_id, recipe_id, artifact_contract_id, status, human_mode,
           initiated_by, sandbox_policy, approval_policy, tool_versions_json,
           reproducibility_hash, started_at_utc)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        ON CONFLICT(id) DO NOTHING
        \"\"\",
        (
            RUN_ID,
            TARGET_ID,
            RECIPE_ID,
            CONTRACT_ID,
            \"running\",
            \"approval-gated\",
            \"artifact-agent\",
            \"workspace-write\",
            \"never\",
            json.dumps({\"codex\": \"codex-cli-background-shell\", \"python\": sys.version.split()[0]}, sort_keys=True),
            \"sha256:art103-service-dep-graph-run\",
            now(),
        ),
    )
    conn.execute(
        \"\"\"
        INSERT INTO envctl_migration_operations
          (id, run_id, operation_type, phase, status, risk, idempotency_key,
           command_hash, command_redacted, input_json)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        ON CONFLICT(id) DO NOTHING
        \"\"\",
        (
            OPERATION_ID,
            RUN_ID,
            \"produce_artifact_record\",
            \"05-artifacts\",
            \"succeeded\",
            \"R2\",
            f\"{TASK_ID}/service-dependency-graph\",
            \"sha256:art103-service-dep-graph-command\",
            \"python3 register existing ART-103 graph artifacts\",
            json.dumps({\"task_id\": TASK_ID, \"repo_path\": \""'${MIGRATION_TARGET_ROOT}", "resolved_target_root": TARGET_ROOT}, sort_keys=True),
        ),
    )
    conn.commit()

graph = read_json("migration-artifacts/art-103_service_dep_graph/service-dependency-graph.json")
base_evidence = [
    rel("generated/execution_packets/ART-103_SERVICE_DEP_GRAPH.json"),
    rel("generated/envctl_target_registry.json"),
    rel("generated/envctl_artifact_registry_report.json"),
    rel("generated/shared_protocol_validation_report.json"),
    rel("generated/task_graph.normalized.json"),
    rel("proof_records/REQ-024_ENVCTL_ARTIFACT_REGISTRY.proof.json"),
    rel("proof_records/REQ-040_SHARED_PROTOCOL_SCHEMAS.proof.json"),
]
common = {
    "run_id": RUN_ID,
    "status": "complete",
    "artifact_type": "migration_artifact",
    "producer_operation_id": OPERATION_ID,
    "contract_id": CONTRACT_ID,
