+            "compilers",
+            "runtimes",
+            "package_managers",
+            "sdks",
+            "ci_cd",
+            "deploy_tools",
+            "containers",
+        ],
+        "nodes": nodes,
+        "edges": edges,
+        "scan_summary": scan,
+        "frontdoors": frontdoors,
+        "envctl_components": components,
+        "version_constraints": {
