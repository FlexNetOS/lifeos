+            "status": "evidenced",
+            "evidence": ["src/envctl/.github/workflows/ci.yml", "src/envctl/.github/workflows/sync-master.yml"],
+            "depends_on": ["compiler:rust", "package-manager:cargo", "sdk:github-cli"],
