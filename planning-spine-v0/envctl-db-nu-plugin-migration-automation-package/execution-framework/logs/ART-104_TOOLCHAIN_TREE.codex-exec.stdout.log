+                elif "envctl bun package-manager wrapper" in text:
+                    entry["wrapper"] = "envctl bun package-manager wrapper"
+                elif text.startswith("#!/"):
+                    entry["wrapper"] = text.splitlines()[0]
+            version = command_version([candidate.as_posix(), "--version"])
+            if version:
