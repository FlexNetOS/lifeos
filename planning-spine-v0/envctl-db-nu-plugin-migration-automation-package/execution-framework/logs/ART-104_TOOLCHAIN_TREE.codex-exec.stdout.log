+BLOCKED_PATTERNS = ("**/.env", "**/secrets/**", "**/private_keys/**", "**/*.pem", "**/*.key")
+SKIP_DIRS = {
+    ".git",
+    ".hg",
+    ".svn",
+    "node_modules",
+    "target",
+    "dist",
+    "build",
+    ".cache",
+    ".cargo",
+    ".rustup",
+    ".toolchains",
+    ".venv",
+    "__pycache__",
