+            is_docker = name.startswith("Dockerfile") or name.startswith("docker-compose")
+            is_make = name in {"Makefile", "Justfile", "Taskfile.yml", "Taskfile.yaml"}
+            if name in MANIFEST_NAMES or is_workflow or is_docker:
