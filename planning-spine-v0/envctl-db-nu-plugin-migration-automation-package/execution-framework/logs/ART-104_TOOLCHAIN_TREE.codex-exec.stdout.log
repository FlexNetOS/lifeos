+    edges = [
+        {"from": node["id"], "to": dep, "type": "requires"}
+        for node in nodes
+        for dep in node.get("depends_on", [])
+    ]
+    evidence_files = sorted(
+        {
+            "generated/envctl_target_registry.json",
