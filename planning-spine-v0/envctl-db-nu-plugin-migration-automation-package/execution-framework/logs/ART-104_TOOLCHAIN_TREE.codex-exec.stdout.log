+            "sha256:pkg-art104",
+            '{"schema_version":1,"task_id":"ART-104_TOOLCHAIN_TREE"}',
+        ),
+    )
+    conn.execute(
+        """
+        INSERT INTO envctl_migration_artifact_contracts
+          (id, contract_name, contract_version, source_package_id, contract_hash, contract_json)
+        VALUES (?, ?, ?, ?, ?, ?)
+        """,
