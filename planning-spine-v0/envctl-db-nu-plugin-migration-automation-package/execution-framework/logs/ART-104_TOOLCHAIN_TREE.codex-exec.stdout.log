+                "risk": "Rust MSRV drift",
+                "evidence": "src/envctl/Cargo.toml and CI enforce rust-version/MSRV 1.88",
+                "mitigation": "Keep cargo check on +1.88.0 and avoid dependency upgrades that raise rust-version.",
+            },
