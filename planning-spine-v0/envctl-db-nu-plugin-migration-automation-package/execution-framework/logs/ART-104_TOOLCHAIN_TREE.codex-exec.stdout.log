+
+def write_markdown(tree: dict[str, Any]) -> None:
+    scan = tree["scan_summary"]
+    lines = [
+        "# ART-104 Toolchain dependency tree",
+        "",
+        f"Generated at: `{tree['generated_at']}`",
+        f"Status: `{tree['status']}`",
+        f"Target root: `{tree['target_root']}`",
