+        "generated_at": now(),
+        "target_root": target_root.as_posix(),
+        "scope_note": "MIGRATION_TARGET_ROOT was not exported when absent; the FlexNetOS primary_root from generated/envctl_target_registry.json is used as the read-only target.",
