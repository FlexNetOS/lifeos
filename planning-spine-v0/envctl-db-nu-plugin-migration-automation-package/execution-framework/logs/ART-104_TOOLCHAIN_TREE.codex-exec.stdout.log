+        },
+        {
+            "id": "runtime:python",
+            "kind": "runtime",
+            "label": "Python tools and validation scripts",
+            "status": "evidenced",
+            "evidence": ["execution-framework/scripts/verify_envctl_db_schema.py", "pyproject.toml"],
+            "depends_on": ["package-manager:pip-pep517"],
+        },
+        {
