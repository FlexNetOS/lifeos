+    out = []
+    for name in names:
+        candidate = target_root / "usr" / "bin" / name
+        entry: dict[str, Any] = {
+            "name": name,
+            "path": rel_to(candidate, target_root),
+            "exists": candidate.exists(),
+            "kind": "missing",
