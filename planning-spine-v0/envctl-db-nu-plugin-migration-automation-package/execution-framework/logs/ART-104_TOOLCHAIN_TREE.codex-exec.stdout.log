+        if candidate.exists():
+            if candidate.is_symlink():
+                entry["kind"] = "symlink"
+                entry["target"] = os.readlink(candidate)
+            elif candidate.is_file():
+                entry["kind"] = "file"
+                text = safe_read_text(candidate, 4096)
+                if "envctl bunx wrapper" in text:
