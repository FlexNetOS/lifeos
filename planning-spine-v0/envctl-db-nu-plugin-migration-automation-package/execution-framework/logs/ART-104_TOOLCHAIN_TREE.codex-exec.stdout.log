name: CI

# Required-check workflow for the `develop` branch. develop is the integration branch and
# GitHub default; once these contexts are required by branch protection, a PR can arm
# auto-merge (`gh pr merge <n> --auto`) and it lands itself fail-closed when they go green.
# CI is the authoritative superset of the local gates.
#
# Feature note: this workspace uses MUTUALLY-EXCLUSIVE cargo features
# (crates/secrets-store-libsql: `remote` ships, `embedded` is an unbuilt placeholder), so CI
# never uses `--all-features` (it would trip the crate's `compile_error!`). Default features
# (= `remote`) are the shipping wiring.

on:
  pull_request:
  push:
    branches: [develop]

# Keep protected develop runs complete, but cancel stale PR/head runs before
# they waste GitHub-hosted minutes.
concurrency:
  group: ci-${{ github.workflow }}-${{ github.event.pull_request.number || github.ref }}
  cancel-in-progress: ${{ github.ref != 'refs/heads/develop' }}

env:
  CARGO_TERM_COLOR: always
  RUST_BACKTRACE: "1"        # debuggable backtraces when a CI test panics
  # envctl currently consumes loop_lib::build_command / SpawnSpec from this upgrade branch;
  # setup-meta-deps.sh intentionally defaults to HEAD for callers that do not need it.
  LOOP_LIB_REF: refs/heads/codex/envctl-runner-command-builder

jobs:
  # Required CI contexts run on GitHub-hosted runners so PR proof comes from a
  # clean environment and never depends on local FlexNetOS runner availability.
  rustfmt:
    name: rustfmt
    runs-on: ubuntu-latest
    timeout-minutes: 10
    steps:
      - uses: actions/checkout@v4
      - name: setup meta path dependencies
        env:
          META_DEPS_<REDACTED:SECRET> secrets.PARENT_REPO_PAT || github.token }}
        run: bash ci/setup-meta-deps.sh
      - uses: dtolnay/rust-toolchain@stable
        with:
          components: rustfmt
      - uses: Swatinem/rust-cache@v2
      - name: cargo fmt --all --check
        run: cargo fmt --all --check

  clippy:
    name: clippy
    runs-on: ubuntu-latest
    timeout-minutes: 25
    steps:
      - uses: actions/checkout@v4
      - name: setup meta path dependencies
        env:
          META_DEPS_<REDACTED:SECRET> secrets.PARENT_REPO_PAT || github.token }}
        run: bash ci/setup-meta-deps.sh
      - uses: dtolnay/rust-toolchain@stable
        with:
          components: clippy
      - uses: Swatinem/rust-cache@v2
      # Default features (= `remote`), workspace-wide. No `--all-features` (mutually-exclusive
      # features) and no `--all-targets` (kept a strict superset of the green preflight set).
      - name: cargo clippy --workspace -- -D warnings
        run: cargo clippy --workspace -- -D warnings

  msrv:
    name: MSRV (Rust 1.88)
    runs-on: ubuntu-latest
    timeout-minutes: 30
    steps:
      - uses: actions/checkout@v4
      - name: setup meta path dependencies
        env:
          META_DEPS_<REDACTED:SECRET> secrets.PARENT_REPO_PAT || github.token }}
        run: bash ci/setup-meta-deps.sh
      - uses: dtolnay/rust-toolchain@1.88.0
      - uses: Swatinem/rust-cache@v2
      # `check`, not `build`: the floor is compiler acceptance for the locked shipping graph.
      # No `--all-features`: crates/secrets-store-libsql has mutually-exclusive store features.
      - name: cargo +1.88.0 check --workspace --locked
        run: cargo +1.88.0 check --workspace --locked

  cargo-audit:
    name: cargo audit
    runs-on: ubuntu-latest
    timeout-minutes: 20
    steps:
      - uses: actions/checkout@v4
      - name: setup meta path dependencies
        env:
          META_DEPS_<REDACTED:SECRET> secrets.PARENT_REPO_PAT || github.token }}
        run: bash ci/setup-meta-deps.sh
      - uses: dtolnay/rust-toolchain@stable
      - uses: Swatinem/rust-cache@v2
      - name: install cargo-audit
        run: cargo install cargo-audit --locked --version 0.22.1
      - name: cargo audit gate
        run: bash ci/gates/cargo-audit.sh

  test:
    name: test
    runs-on: ubuntu-latest
    # Generous but bounded: the cold build dominates and the parallel test run is now substantial
    # (secrets-engine alone ~5 min — the argon2 memory-hard KDF + daemon e2e tests). A real hang
    # (e.g. an await-forever in an e2e stream drain) still fails the check well before the 6h default.
    # NEVER run --test-threads=1 here: the argon2 (memory-hard KDF) crypto tests in
    # secrets-engine/secretd take 20-50s EACH, so serial execution balloons the job to 25-30 min.
    # 30 (was 20): as the suite grew (TASK-0035 grpc e2e, F6 jti, enroll round-trip) the cold-build +
    # parallel-test wall crept to ~18-20 min, so a green run was being CANCELED at the 20-min wall.
    timeout-minutes: 30
    steps:
      - uses: actions/checkout@v4
      - name: setup meta path dependencies
        env:
          META_DEPS_<REDACTED:SECRET> secrets.PARENT_REPO_PAT || github.token }}
        run: bash ci/setup-meta-deps.sh
      - uses: dtolnay/rust-toolchain@stable
      - uses: Swatinem/rust-cache@v2
      # Parallel (default). The few tests that touch process-global env are made hermetic at the
      # source (locate_walks_up clears $META_FILE; runtime XDG test isolates its own var) so the
      # suite is deterministic without serializing it.
