[workspace]
resolver = "2"
members = [
  "crates/agent-env",
  "crates/engine",
  "crates/cli",
  "crates/gui",
  "crates/secrets-engine",
  "crates/secrets-proto",
  "crates/secretd",
  "crates/secretctl",
  "crates/secrets-store-libsql",
]

[workspace.package]
version = "0.1.0"
edition = "2021"
rust-version = "1.88"
license = "MIT OR Apache-2.0"

[workspace.dependencies]
# --- shared rows: keep envctl's tighter pins (superset of env-ctl's caret) ---
serde = { version = "1.0.219", features = ["derive"] }
serde_json = "1.0.135"
# pure-Rust YAML (already in the resolved graph via protox/prost-reflect build path);
# the engine dashboard module reads `.meta.yaml`. Links no C (proven by ci/gates/no-c.sh).
serde_yaml = "0.9.34"
toml = "0.8.19"
anyhow = "1.0.103"
thiserror = "2.0.11"
chrono = { version = "0.4.39", default-features = false, features = ["clock"] }
clap = { version = "4.5.27", features = ["derive"] }
# Pure-Rust shell-completion generation (clap + clap_lex only; no C). Proven C-free by
# ci/gates/no-c.sh. Used by the CLI-only `envctl completions <shell>` verb.
clap_complete = "4.5"
which = "7.0.1"
# --- CONFLICT 1 (HF-17 + OI-6): rustix feature delta. envctl=["process"],
# --- env-ctl=["process","net","time"]. UNION wins (`time` = CLOCK_BOOTTIME for the
# --- OI-6 monotonic clock-rollback fence on the 24h relay window). All pure-Rust on Linux. ---
rustix = { version = "0.38", features = ["process", "net", "time"] }
# Pure-Rust FFI bindings (extern "C" decls only — compiles no C, links no new C lib) used solely by
# secretd for the in-process `mlockall` syscall (FS-S4). Already resolved transitively in secretd's
# tree (tokio -> signal-hook-registry -> errno -> libc), so this pin adds ZERO new lockfile crates.
# NOT on the no-c banned list (aws-lc/openssl/sqlite/mimalloc) — ci/gates/no-c.sh stays green.
libc = "0.2"
# --- envctl-only rows (unchanged) ---
sysinfo = "0.33.1"
glob = "0.3.1"
# Keep the GUI on the MSRV-compatible egui API line, but do not enable eframe's
# full default feature set: accesskit pulls the unmaintained `paste` proc macro
# on Windows, and current Wayland/winit scanner paths pin vulnerable parser
# crates that do not yet have compatible upstream fixes. The CLI/catalog proof
# in this PR does not require those optional GUI stacks.
eframe = { version = "0.33.2", default-features = false, features = ["default_fonts", "glow", "x11"] }
egui = "0.33.2"
egui_extras = "0.33.2"
# --- env-ctl-only rows (added verbatim; no conflict — none of these names exist in envctl today) ---
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter"] }
# Pure-Rust systemd readiness protocol (Type=notify). Writes the READY=1/STOPPING=1 datagram to
# $NOTIFY_SOCKET; a no-op when the env var is unset (safe in tests/non-systemd). Links no C — it is a
# tiny std-only UDS writer (proven by ci/gates/no-c.sh). Closes the secretd crash-loop (no READY=1 =>
# Type=notify 90s timeout => restart storm).
# Keep the systemd notify helper on the MSRV-compatible line. 0.5.x raises
# rust-version above the workspace floor (1.88) without changing envctl's use
# of READY=1 / STOPPING=1 datagrams.
sd-notify = "0.4.5"
tokio = { version = "1.43", features = ["rt-multi-thread", "macros", "net", "sync", "fs", "process", "signal", "time", "io-util"] }
# CVE-2024-47609 / GHSA-4jwc-w2hc-78qv: 0.12.3 is the first tonic 0.12 release with
# the accept-loop DoS fix. Keep the floor explicit so a stale lockfile cannot drift below it.
tonic = "0.12.3"
tonic-build = "0.12.3"
prost = "0.13"
tower = "0.5"
# Paired with the tonic floor above for the public relay listener; Cargo.lock currently resolves
# the workspace hyper line to 1.10.1 and ci/gates/cargo-audit.sh fails on vulnerable regressions.
hyper = { version = "1.10.1", features = ["server", "http1", "http2"] }
hyper-util = { version = "0.1", features = ["tokio", "server", "client-legacy"] }
http-body-util = "0.1"
reqwest = { version = "0.12", default-features = false, features = ["rustls-tls", "http2", "stream"] }
webpki-roots = "0.26"
# agent-env (kasetto absorption, Epic C): pure-Rust gzip via miniz_oxide — NEVER zlib/zlib-ng C
# (`rust_backend`). `tar` is pure-Rust. Both proven C-free by ci/gates/no-c.sh Gate 3.5.
flate2 = { version = "1", default-features = false, features = ["rust_backend"] }
tar = "0.4"
# store backend (OI-1 (a)): libSQL `remote` only — default-features=false drops the bundled
# C-SQLite `core` (libsql-ffi/libsql-sys) so nothing C is linked (proven by ci/gates/no-c.sh Gate 3a).
libsql = { version = "0.9.30", default-features = false, features = ["remote"] }
# crypto (engine; pure-Rust, no C/SQLCipher)
chacha20poly1305 = { version = "0.10", features = ["alloc", "getrandom", "rand_core"] }
argon2 = { version = "0.5", features = ["zeroize"] }
hkdf = "0.12"
# `oid` feature exposes `Sha256: AssociatedOid`, required by rsa's PKCS#1 v1.5 SigningKey<Sha256>
# (the RS256 App-JWT path in secrets-engine `mint_github`). Pure-Rust; links no C.
sha2 = { version = "0.10", features = ["oid"] }
blake3 = "1.5"
zeroize = { version = "1.8", features = ["derive"] }
subtle = "2.6"
rand = "0.8"
getrandom = "0.2"
# GitHub App-JWT (RS256) for the `provider-github` mint seam — pure-Rust RustCrypto, no C linked
# (banned-list in ci/gates/no-c.sh unaffected; proven by Gate 1's `--all-features` tree).
rsa = { version = "0.9", default-features = false, features = ["std", "pem"] }
base64 = { version = "0.22", default-features = false, features = ["alloc"] }
# TLS / local CA: pin ONE rustls on the RING path (NOT aws-lc-rs)
rustls = { version = "0.23", default-features = false, features = ["ring", "logging", "std", "tls12"] }
rustls-pemfile = "2.2"
rustls-pki-types = "1"
rcgen = { version = "0.13", default-features = false, features = ["ring", "pem"] }
# MITM TLS termination (PR-3b, secretd `mitm-ca` only). default-features=false is MANDATORY: a bare
# `tokio-rustls = "0.26"` pulls aws-lc-rs and FAILS no-c. ring-only keeps the single pinned rustls 0.23.
tokio-rustls = { version = "0.26", default-features = false, features = ["ring", "tls12"] }
x509-parser = "0.16"
async-trait = "0.1"
# --- internal path deps: keep envctl's + add the three secrets path deps ---
envctl-engine = { path = "crates/engine" }
envctl-secrets-engine = { path = "crates/secrets-engine" }
envctl-secrets-proto = { path = "crates/secrets-proto" }
envctl-secrets-store-libsql = { path = "crates/secrets-store-libsql" }

# Build all crates in release for a snappy GUI.
[profile.release]
opt-level = 2

