+def is_blocked(path: Path) -> bool:
+    normalized = path.as_posix()
+    return any(fnmatch.fnmatch(normalized, pat) or fnmatch.fnmatch(f"root/{normalized}", pat) for pat in BLOCKED_PATTERNS)
