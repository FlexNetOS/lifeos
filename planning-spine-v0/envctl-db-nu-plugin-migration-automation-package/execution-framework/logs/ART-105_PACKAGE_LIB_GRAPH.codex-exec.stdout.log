+            "python3 -m py_compile scripts/generate_package_lib_graph.py",
+        ],
+        report,
+        report["evidence"],
+        "" if report["status"] == "passed" else "; ".join(report["errors"]),
+        "none" if report["status"] == "passed" else "fix ART-105 package/library graph generation errors",
+    )
+    append_proof(proof)
+    print(
