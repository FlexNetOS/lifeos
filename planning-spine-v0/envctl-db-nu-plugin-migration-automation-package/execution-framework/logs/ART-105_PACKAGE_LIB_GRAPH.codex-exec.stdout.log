+                severity=issue["severity"],
+                status=issue["status"],
+                finding=issue["finding"],
+            )
+        )
+    lines.extend(["", "## Python import scan", "", "| file | local imports | stdlib imports | third-party imports |", "|---|---|---|---|"])
+    for row in graph["python_imports"]["files"]:
+        lines.append(
