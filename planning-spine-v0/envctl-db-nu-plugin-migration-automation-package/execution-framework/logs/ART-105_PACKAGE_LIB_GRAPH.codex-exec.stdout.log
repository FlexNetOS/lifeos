+def write_markdown(graph: dict[str, Any]) -> None:
+    lines = [
+        "# Package/library dependency graph",
+        "",
+        f"Task: `{TASK_ID}`",
+        f"Generated: `{graph['generated_at']}`",
+        "",
+        "## Summary",
