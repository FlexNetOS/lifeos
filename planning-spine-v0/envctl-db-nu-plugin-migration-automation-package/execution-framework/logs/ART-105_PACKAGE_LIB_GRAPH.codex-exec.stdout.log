+            status=report["status"],
+            artifacts=report["summary"]["registered_artifact_count"],
+            evidence=report["summary"]["evidence_count"],
+            validations=report["summary"]["validation_count"],
+        )
+    )
+    if report["status"] != "passed":
+        raise SystemExit(1)
