+            {
+                "validator": "generate_art_107_data_flow_graph.py:registry-hash",
+                "status": "pass",
+                "details": {"hash_expected": True, "validation_evidence_linked": True},
+                "evidence_refs": [relpaths["markdown"], relpaths["json"]],
+            },
