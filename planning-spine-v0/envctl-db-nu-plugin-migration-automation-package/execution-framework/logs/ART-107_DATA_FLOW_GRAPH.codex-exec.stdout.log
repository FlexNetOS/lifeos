+        commands_run,
+        report,
+        report["evidence"],
+        "" if report["status"] == "passed" else "; ".join(report["errors"]),
+        "run VER-300_UNIT_VALIDATION" if report["status"] == "passed" else "fix ART-107 data flow graph errors",
+    )
