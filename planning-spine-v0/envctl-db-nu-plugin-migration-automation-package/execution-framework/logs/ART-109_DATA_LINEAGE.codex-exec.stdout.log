+def main() -> None:
+    artifact = write_artifacts()
+    report_stub = {
+        "schema_version": "1.0",
+        "task_id": TASK_ID,
+        "status": "running",
+        "generated_at": now(),
+        "artifact_summary": artifact["summary"],
+    }
