+TASK_MD = f"{ARTIFACT_DIR}/data-lineage-map.md"
+TASK_JSON = f"{ARTIFACT_DIR}/data-lineage-map.json"
+REPORT_PATH = "execution-framework/generated/art109_data_lineage_report.json"
