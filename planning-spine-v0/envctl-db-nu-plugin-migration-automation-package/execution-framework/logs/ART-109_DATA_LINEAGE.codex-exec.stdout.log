+        ON CONFLICT(target_id) DO UPDATE SET
+          primary_root = excluded.primary_root,
+          descriptor_json = excluded.descriptor_json,
+          descriptor_hash = excluded.descriptor_hash
+        """,
+        (
+            TARGET_DB_ID,
+            "art109-data-lineage-target",
