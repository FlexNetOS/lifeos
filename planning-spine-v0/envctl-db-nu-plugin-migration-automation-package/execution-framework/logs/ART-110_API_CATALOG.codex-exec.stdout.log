+        return False
+    if path.suffix.lower() in BLOCKED_SUFFIXES:
+        return False
+    normalized = path.as_posix()
+    if "/secrets/" in normalized or "/private_keys/" in normalized or normalized.endswith("/.env"):
+        return False
+    return True
