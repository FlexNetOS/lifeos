+    apply_migrations(conn, package_root())
+    fixture = insert_fixture(conn, catalog)
+    registry_results = register_artifacts(conn, fixture)
+    report = build_report(conn, catalog, registry_results)
+    write_runtime_files(report)
+
+    files_changed = [
