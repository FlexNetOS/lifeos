+    digest = hashlib.sha256("\0".join(parts).encode("utf-8")).hexdigest()[:12]
+    raw = "-".join([prefix, *parts])
+    safe = re.sub(r"[^A-Za-z0-9_-]+", "-", raw).strip("-").lower()
+    return f"{safe[:80]}-{digest}"
+
