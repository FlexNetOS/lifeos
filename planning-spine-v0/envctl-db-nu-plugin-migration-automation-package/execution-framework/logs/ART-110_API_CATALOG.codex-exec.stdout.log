+                "surface": "event",
+                "surface_id": event["event_id"],
+                "schema_refs": event["schema_refs"],
+                "auth": "n/a",
+                "consumers": event["consumers"],
+                "version": event["version"],
+                "source_files": event["source_files"],
+            }
