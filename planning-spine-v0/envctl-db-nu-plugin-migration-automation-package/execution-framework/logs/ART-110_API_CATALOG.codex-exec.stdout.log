+def classify_auth_name(name: str) -> str:
+    lowered = name.lower()
+    if "jwt" in lowered:
+        return "jwt"
+    if "oauth" in lowered:
+        return "oauth"
+    if "token" in lowered:
+        return "token"
+    if "key" in lowered:
