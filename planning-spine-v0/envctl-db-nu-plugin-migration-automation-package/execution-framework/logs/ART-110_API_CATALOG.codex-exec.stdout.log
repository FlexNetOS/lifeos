+
+def build_contract_map(endpoints: list[dict[str, Any]], events: list[dict[str, Any]], schemas: list[dict[str, Any]]) -> list[dict[str, Any]]:
+    schema_by_name = {schema["name"]: schema for schema in schemas}
+    rows = []
