+            {
+                "contract_id": stable_slug("contract", endpoint["endpoint_id"]),
+                "surface": "endpoint",
+                "surface_id": endpoint["endpoint_id"],
+                "schema_refs": schema_refs,
+                "auth": endpoint["auth"],
+                "consumers": endpoint["consumers"],
+                "version": endpoint["version"],
+                "source_files": endpoint["source_files"],
+            }
+        )
+    for event in events:
