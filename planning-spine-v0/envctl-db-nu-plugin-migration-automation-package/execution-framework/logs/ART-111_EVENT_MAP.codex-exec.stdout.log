+def md_table(items: list[dict[str, Any]], limit: int = 24) -> list[str]:
+    lines = ["| file | line | signal | evidence |", "|---|---:|---|---|"]
+    for item in items[:limit]:
+        lines.append(
+            "| `{}` | {} | `{}` | {} |".format(
+                item["path"],
+                item["line"],
+                item["signal"],
+                item["snippet"].replace("|", "\\|"),
+            )
+        )
+    if len(items) > limit:
+        lines.append(f"| ... |  |  | {len(items) - limit} more entries in JSON artifact |")
+    return lines
