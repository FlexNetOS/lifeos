+def count_files(base: Path, rel: str) -> int:
+    start = base / rel
+    if not start.exists():
+        return 0
+    count = 0
+    for path in start.rglob("*"):
+        if path.is_file() and is_allowed_file(path.relative_to(start)):
+            count += 1
+    return count
+
