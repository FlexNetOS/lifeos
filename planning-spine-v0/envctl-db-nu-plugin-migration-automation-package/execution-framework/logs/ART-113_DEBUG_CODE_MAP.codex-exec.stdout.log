+           initiated_by, sandbox_policy, approval_policy, tool_versions_json,
+           reproducibility_hash, started_at_utc)
+        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
+        """,
+        (
+            RUN_ID,
+            TARGET_DB_ID,
+            RECIPE_ID,
+            CONTRACT_ID,
+            "running",
+            "approval-gated",
+            "artifact-agent",
+            "workspace-write",
+            "never",
+            json.dumps({"python": "stdlib", "scan": "static"}),
+            "sha256:art113-debug-code-map-run",
+            now(),
