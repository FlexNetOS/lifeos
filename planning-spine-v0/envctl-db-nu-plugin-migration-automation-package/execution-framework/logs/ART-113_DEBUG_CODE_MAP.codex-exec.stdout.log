+
+
+def register_artifacts(artifact: dict[str, Any]) -> dict[str, Any]:
+    conn = sqlite3.connect(":memory:")
+    conn.execute("PRAGMA foreign_keys = ON")
+    apply_migrations(conn, package_root())
