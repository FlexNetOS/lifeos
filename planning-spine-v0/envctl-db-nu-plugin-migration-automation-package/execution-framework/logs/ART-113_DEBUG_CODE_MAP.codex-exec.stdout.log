+        (
+            TARGET_DB_ID,
+            "art113-debug-code-map-target",
+            "mixed",
+            target_root,
+            "/home/flexnetos/lifeos",
+            json.dumps({"schema_version": 1, "task_id": TASK_ID, "target_root": target_root}, sort_keys=True),
+            "sha256:art113-debug-code-map-target",
+            "approval-gated",
+            "R2",
+        ),
