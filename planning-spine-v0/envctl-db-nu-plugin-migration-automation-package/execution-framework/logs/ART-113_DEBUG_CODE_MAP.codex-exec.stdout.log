+        ("database", re.compile(r"\b(sqlite3|psycopg|postgres|mysql|redis|duckdb|connect\(|Pool::|rusqlite)\b", re.IGNORECASE)),
+        ("filesystem", re.compile(r"\b(read_text|write_text|open\(|File::|fs::|PathBuf|copy|rename|mkdir|rglob)\b")),
