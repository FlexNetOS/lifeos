+def is_blocked(path: Path) -> bool:
+    parts = set(path.parts)
+    name = path.name
+    return (
+        name == ".env"
+        or "secrets" in parts
+        or "private_keys" in parts
+        or name.endswith(".pem")
+        or name.endswith(".key")
+    )
