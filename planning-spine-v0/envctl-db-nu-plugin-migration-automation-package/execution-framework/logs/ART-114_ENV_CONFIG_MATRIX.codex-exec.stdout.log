+
+def proof_path(relpath: str) -> str:
+    raw = Path(relpath)
+    if raw.parts and raw.parts[0] == "migration-artifacts":
+        return f"execution-framework/{relpath}"
+    return relpath
+
+
+def target_descriptor() -> dict[str, Any]:
+    return {
