+    ]
+    for item in matrix["matrix"]:
+        rows.append(f"| {item['dimension']} | {item['dev']} | {item['stage']} | {item['prod']} |")
+    rows.extend(["", "## Environment Detail", ""])
+    for env in matrix["environments"]:
