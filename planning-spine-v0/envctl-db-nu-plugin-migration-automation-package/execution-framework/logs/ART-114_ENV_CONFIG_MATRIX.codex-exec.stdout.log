+    insert_art114_fixture(conn)
+    registrations = register_artifacts(conn, artifact_paths)
+    verification = verify_registry(conn, registrations)
+    status = "passed" if not verification["errors"] else "failed"
+    report = {
+        "schema_version": "1.0",
+        "task_id": TASK_ID,
+        "status": status,
+        "generated_at": now(),
+        "started_at": started_at,
