+           reproducibility_hash, started_at_utc, completed_at_utc)
+        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
+        ON CONFLICT(id) DO UPDATE SET
+          status = excluded.status,
+          completed_at_utc = excluded.completed_at_utc
+        """,
+        (
+            RUN_ID,
+            TARGET_DB_ID,
