+                "reference_kind": item["reference_kind"],
+                "reference_count": len(paths),
+                "paths": paths[:20],
+                "value_captured": False,
+            }
+        )
+
+    config_by_kind = Counter(item["kind"] or "unknown" for item in config_files)
+    return {
+        "target_root": str(target_root),
+        "scan_policy": {
