+def render_markdown(payload: dict[str, Any]) -> str:
+    inv = payload["inventory"]
+    summary = inv["summary"]
+    lines = [
+        "# Configuration Inventory",
+        "",
+        f"Generated: `{payload['generated_at']}`",
+        f"Task: `{payload['task_id']}`",
+        f"Target root: `{inv['target_root']}`",
+        "",
