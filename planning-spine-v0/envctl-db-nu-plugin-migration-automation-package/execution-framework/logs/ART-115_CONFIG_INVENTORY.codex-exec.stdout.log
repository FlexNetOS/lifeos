+        lines.append(f"| `{item['name']}` | {item['reference_count']} | {sample} |")
+
+    lines.extend(["", "## Secret References", "", "Secret values were not captured. Only names and reference locations are listed.", "", "| name | kind | refs | sample paths |", "|---|---|---:|---|"])
