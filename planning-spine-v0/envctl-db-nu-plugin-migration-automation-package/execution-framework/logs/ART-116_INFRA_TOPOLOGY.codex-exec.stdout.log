  evidence_json TEXT,
  created_at_utc TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ','now')),
  FOREIGN KEY(run_id) REFERENCES envctl_migration_runs(id)
);

CREATE TABLE IF NOT EXISTS envctl_migration_approvals (
