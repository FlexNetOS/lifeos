+def markdown_table(rows: list[list[str]]) -> str:
+    if not rows:
+        return ""
+    header = "| " + " | ".join(rows[0]) + " |"
+    sep = "| " + " | ".join(["---"] * len(rows[0])) + " |"
+    body = ["| " + " | ".join(row) + " |" for row in rows[1:]]
+    return "\n".join([header, sep, *body])
