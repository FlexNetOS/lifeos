+                        "evidence_refs": [record["path"]],
+                    },
+                    {
+                        "validator": "generate_art116_infra_topology.py:category-coverage",
+                        "status": "pass",
+                        "details": {
+                            "required_categories": list(CATEGORY_PATTERNS),
+                            "covered_categories": [
