+                        },
+                        "evidence_refs": common_evidence[:3],
+                    },
+                ],
+            }
+        )
+        results.append(result)
+
+    fetched = [fetch_artifact(conn, RUN_ID, record["artifact_id"]) for record in records]
+    return {
+        "schema_version": "1.0",
+        "task_id": TASK_ID,
+        "generated_at": now(),
+        "status": "passed",
+        "run_id": RUN_ID,
+        "operation_id": OPERATION_ID,
