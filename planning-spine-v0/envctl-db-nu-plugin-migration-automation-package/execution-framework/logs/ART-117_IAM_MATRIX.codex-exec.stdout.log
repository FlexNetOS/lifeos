+
+BLOCKED_PATH_PATTERNS = ("**/.env", "**/secrets/**", "**/private_keys/**", "**/*.pem", "**/*.key")
+SCAN_EXCLUDES = (
+    ".git/**",
+    "**/__pycache__/**",
+    "execution-framework/scripts/__pycache__/**",
+    "execution-framework/migration-artifacts/**",
+    "execution-framework/logs/**",
+    "execution-framework/proof_records/**",
+)
+SECURITY_TERMS = (
+    "approval",
+    "human_mode",
+    "sandbox",
+    "permission",
+    "role",
+    "token",
+    "cert",
+    "credential",
+    "secret",
+    "service account",
+    "service_account",
+    "identity",
+    "auth",
+    "api_key",
+    "oauth",
+    "github",
+)
