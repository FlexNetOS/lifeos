+def should_scan(relpath: str) -> bool:
+    normalized = relpath.replace("\\", "/")
+    if is_blocked_rel(normalized):
+        return False
+    return not any(fnmatch.fnmatch(normalized, pattern) for pattern in SCAN_EXCLUDES)
