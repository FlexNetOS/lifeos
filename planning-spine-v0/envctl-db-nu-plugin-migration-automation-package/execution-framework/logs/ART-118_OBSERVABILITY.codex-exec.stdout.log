+
+BLOCKED_PATTERNS = ("**/.env", "**/secrets/**", "**/private_keys/**", "**/*.pem", "**/*.key")
+DIR_EXCLUDES = {
+    ".git",
+    ".hg",
+    ".svn",
+    ".cache",
+    ".kb",
+    ".venv",
+    "__pycache__",
+    "node_modules",
+    "target",
+    "dist",
+    "build",
+    "private_keys",
+    "secrets",
+}
+TEXT_SUFFIXES = {
+    ".c",
+    ".cc",
+    ".conf",
+    ".cpp",
+    ".go",
+    ".json",
+    ".kdl",
+    ".md",
+    ".nix",
+    ".nu",
