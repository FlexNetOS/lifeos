+def categorize_text(haystack: str) -> list[tuple[str, str]]:
+    lowered = haystack.lower()
+    matches: list[tuple[str, str]] = []
+    for category, terms in CATEGORY_TERMS.items():
+        for term in terms:
+            if term in lowered:
