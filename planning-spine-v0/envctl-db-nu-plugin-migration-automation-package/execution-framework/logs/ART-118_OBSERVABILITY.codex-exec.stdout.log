+                if not matches:
+                    continue
+                for category, term in matches:
+                    if len(categories[category]) < max_per_category:
+                        categories[category].append(
+                            {
+                                "source": rel,
+                                "evidence_kind": "content_keyword",
+                                "keyword": term,
+                                "line": line_no,
+                            }
+                        )
+                break
+
+    return {
