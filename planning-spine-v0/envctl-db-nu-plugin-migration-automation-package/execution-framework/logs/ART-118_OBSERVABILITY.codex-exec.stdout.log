+def scan_observability_evidence(target_root: Path, max_per_category: int = 80) -> dict[str, Any]:
+    categories: dict[str, list[dict[str, Any]]] = {name: [] for name in CATEGORY_TERMS}
+    visited = 0
+    content_checked = 0
+    blocked_skipped = 0
