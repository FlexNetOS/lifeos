+    ".venv",
+    "__pycache__",
+    "node_modules",
+    "target",
+    "dist",
+    "build",
+    "private_keys",
+    "secrets",
+}
+TEXT_SUFFIXES = {
+    ".c",
+    ".cc",
+    ".conf",
+    ".cpp",
+    ".go",
+    ".json",
+    ".kdl",
+    ".md",
+    ".nix",
+    ".nu",
+    ".py",
+    ".rs",
+    ".sh",
+    ".sql",
+    ".toml",
+    ".ts",
+    ".tsx",
+    ".vue",
+    ".yaml",
+    ".yml",
