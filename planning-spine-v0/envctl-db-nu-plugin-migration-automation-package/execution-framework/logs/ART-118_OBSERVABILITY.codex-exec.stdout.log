+        registry.get("registry_rows", [{}])[0],
+    )
+    primary_root = os.environ.get("MIGRATION_TARGET_ROOT") or target.get("primary_root") or "/home/flexnetos/FlexNetOS"
+    return {
+        "target_registry_status": registry.get("status"),
+        "target": target,
