+    content_checked = 0
+    blocked_skipped = 0
+    if not target_root.exists():
+        return {
+            "target_root": target_root.as_posix(),
+            "exists": False,
+            "visited_file_count": 0,
+            "content_checked_count": 0,
+            "blocked_skipped_count": 0,
+            "categories": categories,
+        }
