+def register_artifacts(conn: sqlite3.Connection, payload: dict[str, Any]) -> tuple[list[dict[str, Any]], list[dict[str, Any]]]:
+    registry = ArtifactRegistry(conn, package_root())
+    evidence_refs = [
+        CANONICAL_WAVE_MD,
+        CANONICAL_MIGRATION_MD,
+        TASK_MD,
+        TASK_JSON,
+        *SOURCE_INPUTS,
