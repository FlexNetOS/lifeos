from dataclasses import dataclass, field
from pathlib import Path
from typing import Any


VALID_ARTIFACT_STATUSES = {"complete", "partial", "unknown", "blocked"}
VALID_VALIDATION_STATUSES = {"pass", "fail", "warn", "blocked", "unknown"}
