+                "proof_records/REQ-026_ENVCTL_ROLLBACK_CHECKPOINTS.proof.json",
+                "proof_records/REQ-040_SHARED_PROTOCOL_SCHEMAS.proof.json",
+            ],
+            "success_criteria": [
+                "REQ-024, REQ-026, and REQ-040 show completed proof records.",
