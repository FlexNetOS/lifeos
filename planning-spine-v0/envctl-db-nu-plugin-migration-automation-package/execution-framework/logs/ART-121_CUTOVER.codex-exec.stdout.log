+            "| {task_id} | {title} | {status} | {proof_uri} |".format(
+                task_id=gate["task_id"],
+                title=gate["title"].replace("|", "\\|"),
+                status=gate["status"],
+                proof_uri=gate["proof_uri"],
+            )
+        )
+
+    lines.extend(
+        [
+            "",
+            "## Checklist",
+            "",
+            "| step | phase | status | blocking | title | intent | owner |",
+            "|---|---|---|---|---|---|---|",
+        ]
+    )
