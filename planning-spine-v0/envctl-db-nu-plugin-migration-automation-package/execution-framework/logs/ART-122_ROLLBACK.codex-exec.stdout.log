+def render_markdown(payload: dict[str, Any]) -> str:
+    lines = [
+        "# Rollback Plan",
+        "",
+        f"- Task: `{TASK_ID}`",
+        "- Contract artifact: `artifact:07-cutover-rollback-plan-md`",
