+        task = tasks.get(task_id, {})
+        entries.append(
+            {
+                "task_id": task_id,
+                "title": task.get("title", task_id),
+                "status": statuses.get(task_id, "pending"),
+                "proof_uri": task.get("proof_uri", ""),
+            }
+        )
+    return entries
+
