+        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
+        """,
+        (
+            RUN_ID,
+            TARGET_ID,
+            RECIPE_ID,
+            CONTRACT_ID,
+            "running",
+            "approval-gated",
+            "artifact-agent",
+            "workspace-write",
+            "never",
+            json.dumps({"python": "stdlib", "sqlite": sqlite3.sqlite_version}, sort_keys=True),
