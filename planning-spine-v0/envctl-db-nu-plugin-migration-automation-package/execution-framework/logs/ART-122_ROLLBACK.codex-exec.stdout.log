+        if row.get("producer_task_id") == TASK_ID
+    ]
+
+
+def build_gate_entries(tasks: dict[str, dict[str, str]], statuses: dict[str, str]) -> list[dict[str, str]]:
+    entries: list[dict[str, str]] = []
