        "execution-framework/docs/ENVCTL_ARTIFACT_REGISTRY.md",
        "execution-framework/state/REQ-024_ENVCTL_ARTIFACT_REGISTRY.heartbeat.json",
        "execution-framework/logs/REQ-024_ENVCTL_ARTIFACT_REGISTRY.log",
