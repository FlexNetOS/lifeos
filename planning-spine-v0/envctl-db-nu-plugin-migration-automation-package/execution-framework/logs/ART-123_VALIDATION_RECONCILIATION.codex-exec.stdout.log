+            status=report["status"],
+            parity=reconciliation["parity"]["passed"],
+            artifacts=len(report["artifact_index_rows"]),
+            validations=report["validation_scorecard_row"],
+        )
+    )
+    if report["status"] != "passed":
+        raise SystemExit(1)
+
+
+if __name__ == "__main__":
+    main()

