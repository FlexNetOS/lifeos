+    records = [
+        {
+            **common,
+            "artifact_id": "art-123-validation-reconciliation-md",
+            "title": "ART-123 Validation Reconciliation Reports",
+            "artifact_type": "validation_reconciliation_report",
+            "path": rel(TASK_MD),
