def read_sql(base: Path, relpath: str) -> str:
    path = base / relpath
    if not path.exists():
        raise FileNotFoundError(path)
    return path.read_text(encoding="utf-8")


def apply_migrations(conn: sqlite3.Connection, base: Path) -> list[dict]:
    applied = []
    for relpath in MIGRATION_FILES:
        sql = read_sql(base, relpath)
        conn.executescript(sql)
        applied.append(
            {
                "path": relpath,
                "sha256": sha256_file(base / relpath),
                "bytes": len(sql.encode("utf-8")),
            }
        )
    return applied


def table_columns(conn: sqlite3.Connection, table: str) -> list[dict]:
    return [
        {
            "cid": row[0],
            "name": row[1],
            "type": row[2],
            "not_null": bool(row[3]),
            "default": row[4],
            "primary_key": bool(row[5]),
        }
        for row in conn.execute(f"PRAGMA table_info({table})")
    ]


def foreign_keys(conn: sqlite3.Connection, table: str) -> list[dict]:
    return [
        {
            "id": row[0],
            "seq": row[1],
            "table": row[2],
            "from": row[3],
            "to": row[4],
            "on_update": row[5],
            "on_delete": row[6],
            "match": row[7],
        }
        for row in conn.execute(f"PRAGMA foreign_key_list({table})")
    ]


def indexes(conn: sqlite3.Connection, table: str) -> list[dict]:
    result = []
    for row in conn.execute(f"PRAGMA index_list({table})"):
        index_name = row[1]
        result.append(
            {
                "name": index_name,
                "unique": bool(row[2]),
                "origin": row[3],
                "partial": bool(row[4]),
                "columns": [col[2] for col in conn.execute(f"PRAGMA index_info({index_name})")],
            }
        )
    return result


**Considering output checksums**

I’m grappling with how to include output checksums in the report after writing, since JSON includes checksums that can't be stable. I could just place the output checksums in the registration report after files are written, but how do I compute them for the JSON report before writing? Maybe I could write the JSON report after the build, without a self-hash. The task asks for checksums, so including input checksums and output checksums for the reports seems better. It could be a two-phase approach, creating a separate registry report for artifact hashes.
**Evaluating JSON reporting**

I'm figuring out that the target JSON can have input and planned output metadata, but not its own hash. The registry report will contain hashes of the target JSON. I need to register artifacts using an in-memory database, which will involve applying migrations and inserting fixtures. The seed could contain package, contract, recipe, and possibly the target too. I also wonder if I should reference the target in the run inserts. Existing ART128 seems to handle target inserts well, using a conflict resolution pattern that I could replicate.
