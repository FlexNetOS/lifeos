+            "execution-framework/generated/shared_protocol_validation_report.json",
+            "execution-framework/generated/status_from_proofs.json",
+            "execution-framework/generated/contract_manifest.json",
+        ],
+    }
+
+
+def main() -> None:
+    matrix = build_matrix()
+    write_artifacts(matrix)
+
