+        "run VER-300_UNIT_VALIDATION to execute the coverage matrix against runtime fixtures",
+    )
+    append_proof(proof)
+
+    print(
+        "ART-124 test coverage status={status} classes={classes} artifacts={artifacts} validations={validations}".format(
