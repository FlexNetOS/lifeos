+
+def status_for(statuses: dict[str, str], task_id: str) -> str:
+    return statuses.get(task_id, "unknown")
+
+
+def evidence_hashes(paths: list[str]) -> dict[str, str | None]:
+    base = package_root()
+    out: dict[str, str | None] = {}
+    for item in paths:
+        p = base / item
+        out[item] = sha256_file(p)
+    return out
