+    log_path = root() / "logs" / f"{TASK_ID}.log"
+    log_path.write_text(json.dumps(report, indent=2, sort_keys=False) + "\n", encoding="utf-8")
+    heartbeat_path = root() / "state" / f"{TASK_ID}.heartbeat.json"
