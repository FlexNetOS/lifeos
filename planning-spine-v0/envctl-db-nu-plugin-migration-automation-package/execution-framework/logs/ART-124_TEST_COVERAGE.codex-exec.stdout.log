+        },
+        {
+            "coverage_id": "TCOV-REGRESSION-001",
+            "test_class": "regression",
+            "scope": "artifact contract paths, proof ledger, task graph packets, registry hashes, and reusable generated reports across repeated package runs",
+            "required_checks": [
