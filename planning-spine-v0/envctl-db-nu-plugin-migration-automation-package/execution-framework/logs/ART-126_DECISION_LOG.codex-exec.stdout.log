+        "registry_checks": registry_checks,
+        "summary": {
+            "registered_artifact_count": len(registry_results),
+            "validation_count": validation_count,
+            "evidence_count": evidence_count,
+            "graph_edge_count": graph_count,
+        },
+        "errors": errors,
+    }
+
