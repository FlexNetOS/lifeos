+        """,
+        (
+            "target-art126",
+            "flexnetos-vs-lifeos",
+            "mixed",
+            "/home/flexnetos/FlexNetOS",
+            "/home/flexnetos/lifeos",
+            '{"schema_version":1,"target_id":"flexnetos-vs-lifeos","source":"generated/envctl_target_registry.json"}',
+            "sha256:art126-target",
+            "approval-gated",
+            "R2",
+        ),
+    )
+    conn.execute(
+        """
