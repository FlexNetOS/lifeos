+    shared_protocol = read_json(base / "generated" / "shared_protocol_manifest.json")
+    contract_manifest = read_json(base / "generated" / "contract_manifest.json")
+    packet = read_json(base / "generated" / "execution_packets" / f"{TASK_ID}.json")
