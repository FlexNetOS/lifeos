+            "path": paths["task_markdown"],
+        },
+        {
+            **common,
+            "artifact_id": "art-126-decision-log-json",
+            "title": "ART-126 Decision Log JSON",
+            "artifact_type": "machine_readable_record",
+            "path": paths["task_json"],
+        },
+        {
+            **common,
+            "artifact_id": "09-governance-decision-log-md",
