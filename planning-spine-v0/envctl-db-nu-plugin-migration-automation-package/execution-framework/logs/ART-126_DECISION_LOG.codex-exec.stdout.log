+                "Rollback remains scoped to files added by this task and the proof ledger entry.",
+            ],
+        },
+        {
+            "id": "ADR-ART126-006",
+            "title": "Keep filesystem artifact work inside allowed target and execution paths",
+            "status": "accepted",
