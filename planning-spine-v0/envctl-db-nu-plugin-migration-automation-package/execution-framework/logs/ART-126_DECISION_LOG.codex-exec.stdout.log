+            "status": db_model["status"],
+            "table_count": db_model["summary"]["actual_table_count"],
+            "view_count": db_model["summary"]["actual_view_count"],
+            "capability_count": db_model["summary"]["capability_count"],
+        },
+        "artifact_registry": {
