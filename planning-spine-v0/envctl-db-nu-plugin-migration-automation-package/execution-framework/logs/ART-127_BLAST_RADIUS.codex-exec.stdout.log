        "hashes",
        "producers",
        "contract_ids",
        "provenance",
        "validation_links",
        "fail_closed_rejections",
    ]:
        lines.append(f"| {key.replace('_', ' ')} | {'yes' if coverage[key] else 'no'} |")
    lines.extend(
        [
