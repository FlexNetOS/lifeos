            "validations": [
                {
                    "validator": "verify_artifact_registry.py:schema-shape",
                    "status": "pass",
                    "details": {"required_fields": ["artifact_id", "run_id", "title", "status"]},
                    "evidence_refs": ["schemas/artifact_record.schema.json"],
                },
                {
