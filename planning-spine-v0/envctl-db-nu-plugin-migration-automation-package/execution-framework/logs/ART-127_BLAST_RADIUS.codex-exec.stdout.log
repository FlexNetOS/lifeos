+                "codex exec packet workflow",
+                "proof log capture",
+            ],
+            "blocked_tasks": ["ARTIFACTS", "REL-401_HANDOFF"],
+            "detect_with": ["codex exec < generated/execution_packets/ART-127_BLAST_RADIUS.json"],
