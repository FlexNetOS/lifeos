+        "execution-framework/proof_records/proof_ledger.jsonl",
+    ]
+    commands_run = [
+        "python3 scripts/generate_art_127_blast_radius.py",
+        "python3 -m py_compile scripts/generate_art_127_blast_radius.py",
+    ]
+    evidence = [
