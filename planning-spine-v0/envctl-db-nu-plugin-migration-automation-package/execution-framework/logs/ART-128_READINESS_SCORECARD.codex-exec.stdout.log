            "contract_ids": artifact["links"].get("contract_id") == fixture["contract_id"],
            "provenance": artifact["evidence"].get("provenance", {}).get("task_id") == TASK_ID,
            "validation_links": validation_count >= 2 and graph_count >= 4,
