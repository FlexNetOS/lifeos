                  evidence_kind = excluded.evidence_kind,
                  sha256 = excluded.sha256,
                  redacted = excluded.redacted,
                  metadata_json = excluded.metadata_json
                """,
                (
                    evidence_id,
                    item.run_id,
                    item.producer_operation_id,
                    ref,
                    "artifact_registry_link",
                    sha,

