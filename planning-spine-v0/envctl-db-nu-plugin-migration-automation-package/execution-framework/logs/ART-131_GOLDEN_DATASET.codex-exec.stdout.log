+            "artifact_id": "art-131-golden-dataset-json",
+            "run_id": RUN_ID,
+            "title": "ART-131 Golden Dataset JSON",
+            "status": "complete",
+            "artifact_type": "machine_readable_validation_sample",
+            "path": TASK_JSON,
