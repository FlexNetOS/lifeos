+            "|---|---|---|---|---|---|",
+        ]
+    )
+    for item in payload["comparison_streams"]:
+        lines.append(
+            "| {stream} | `{source}` | {old} | {new} | {threshold} | `{status}` |".format(
+                stream=item["stream_id"],
