+def source_hashes(paths: list[str]) -> dict[str, str]:
+    hashes = {}
+    for path in paths:
+        candidate = package_root() / path
+        if candidate.exists() and candidate.is_file():
+            hashes[path] = sha256_file(candidate)
+    return hashes
