+            "",
+            "## Evidence Inputs",
+            "",
+            "| input | path |",
+            "|---|---|",
+        ]
+    )
+    for name, path in payload["source_inputs"].items():
+        lines.append(f"| {name} | `{path}` |")
+    return "\n".join(lines) + "\n"
