+def build_report(conn: sqlite3.Connection, payload: dict[str, Any], registry_results: list[dict[str, Any]]) -> dict[str, Any]:
+    artifacts = [
+        fetch_artifact(conn, RUN_ID, "art132-parity-dashboard-md"),
