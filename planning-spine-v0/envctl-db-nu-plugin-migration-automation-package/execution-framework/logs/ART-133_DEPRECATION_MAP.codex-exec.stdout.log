+def write_json(path: Path, payload: Any) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(json.dumps(payload, indent=2, sort_keys=False) + "\n", encoding="utf-8")
+
+
+def write_text(path: Path, text: str) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(text, encoding="utf-8")
+
+
+def read_json_if_exists(path: Path) -> dict[str, Any]:
+    if not path.is_file():
+        return {}
+    return json.loads(path.read_text(encoding="utf-8"))
+
+
+def read_contract_row() -> dict[str, Any]:
+    manifest = read_json_if_exists(root() / "generated" / "contract_manifest.json")
+    for row in manifest.get("contract", {}).get("rows", []):
+        if row.get("artifact_id") == "02-target-state-deprecation-map-md":
+            return row
+    raise RuntimeError("contract row not found for 02-target-state-deprecation-map-md")
+
+
+def load_source_signals() -> dict[str, Any]:
+    base = root()
+    package_graph = read_json_if_exists(base / "migration-artifacts" / "art-105_package_lib_graph" / "package_lib_graph.json")
+    target_descriptor = (base / "migration-artifacts" / "_meta" / "flexnetos-vs-lifeos.target-descriptor.yaml")
+    adapter_spec = package_root() / "specs" / "flexnetos-adapter.md"
+    strategy = package_root() / "prompts" / "STRATEGY_DECISION.md"
+    shared_protocol = read_json_if_exists(base / "generated" / "shared_protocol_validation_report.json")
+    db_model = read_json_if_exists(base / "generated" / "envctl_migration_db_model.json")
+    return {
+        "package_graph_summary": package_graph.get("summary", {}),
+        "package_graph_issues": package_graph.get("issues", []),
+        "target_descriptor_path": str(target_descriptor.relative_to(base)) if target_descriptor.is_file() else None,
+        "target_descriptor_exists": target_descriptor.is_file(),
+        "adapter_spec_path": "specs/flexnetos-adapter.md" if adapter_spec.is_file() else None,
+        "strategy_decision_path": "prompts/STRATEGY_DECISION.md" if strategy.is_file() else None,
