+def summarize(entries: list[dict[str, Any]]) -> dict[str, int]:
+    out = {"retired": 0, "replaced": 0, "wrapped": 0, "preserved": 0}
+    for item in entries:
+        out[item["classification"]] = out.get(item["classification"], 0) + 1
+    return out
+
