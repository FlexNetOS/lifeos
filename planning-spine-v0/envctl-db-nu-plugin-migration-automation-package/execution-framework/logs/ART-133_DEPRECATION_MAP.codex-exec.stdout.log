+
+
+def write_json(path: Path, payload: Any) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(json.dumps(payload, indent=2, sort_keys=False) + "\n", encoding="utf-8")
+
+
+def write_text(path: Path, text: str) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(text, encoding="utf-8")
+
+
+def read_json_if_exists(path: Path) -> dict[str, Any]:
+    if not path.is_file():
+        return {}
+    return json.loads(path.read_text(encoding="utf-8"))
+
+
+def read_contract_row() -> dict[str, Any]:
+    manifest = read_json_if_exists(root() / "generated" / "contract_manifest.json")
+    for row in manifest.get("contract", {}).get("rows", []):
+        if row.get("artifact_id") == "02-target-state-deprecation-map-md":
+            return row
+    raise RuntimeError("contract row not found for 02-target-state-deprecation-map-md")
+
+
+def load_source_signals() -> dict[str, Any]:
+    base = root()
+    package_graph = read_json_if_exists(base / "migration-artifacts" / "art-105_package_lib_graph" / "package_lib_graph.json")
+    target_descriptor = (base / "migration-artifacts" / "_meta" / "flexnetos-vs-lifeos.target-descriptor.yaml")
+    adapter_spec = package_root() / "specs" / "flexnetos-adapter.md"
+    strategy = package_root() / "prompts" / "STRATEGY_DECISION.md"
+    shared_protocol = read_json_if_exists(base / "generated" / "shared_protocol_validation_report.json")
+    db_model = read_json_if_exists(base / "generated" / "envctl_migration_db_model.json")
+    return {
+        "package_graph_summary": package_graph.get("summary", {}),
+        "package_graph_issues": package_graph.get("issues", []),
+        "target_descriptor_path": str(target_descriptor.relative_to(base)) if target_descriptor.is_file() else None,
+        "target_descriptor_exists": target_descriptor.is_file(),
+        "adapter_spec_path": "specs/flexnetos-adapter.md" if adapter_spec.is_file() else None,
+        "strategy_decision_path": "prompts/STRATEGY_DECISION.md" if strategy.is_file() else None,
+        "shared_protocol_status": shared_protocol.get("status"),
+        "db_model_status": db_model.get("status"),
+        "db_artifact_registry_covered": db_model.get("capability_coverage", {}).get("artifact registry", {}).get("covered"),
+    }
+
+
+def build_entries(signals: dict[str, Any]) -> list[dict[str, Any]]:
+    issues = {item.get("id"): item for item in signals.get("package_graph_issues", [])}
+    return [
+        {
+            "component_id": "deprecated-generated-bytecode-cache",
+            "component": "source/codex-flexnetos-migration-prompt-package/helpers/__pycache__",
+            "classification": "retired",
+            "disposition": "Exclude from authoritative migration source and regenerated package outputs.",
+            "rationale": issues.get("ART105-DEP-001", {}).get(
+                "finding",
+                "Generated bytecode cache files are compatibility artifacts, not source contract material.",
+            ),
+            "replacement": "Source helper scripts and package manifest entries without CPython cache files.",
+            "owner": "artifact-agent",
+            "risk": "medium",
+            "validation": "Package graph deprecation issue is captured and linked to this map.",
+            "evidence_refs": ["migration-artifacts/art-105_package_lib_graph/package_lib_graph.json"],
+        },
+        {
+            "component_id": "prompt-only-artifact-state",
+            "component": "Markdown-only migration artifact status",
+            "classification": "replaced",
+            "disposition": "Replace with envctl artifact rows, content hashes, validation records, and graph links.",
+            "rationale": "The envctl DB model covers artifact registry, evidence, graph edges, and validations so artifact state is queryable and replayable.",
+            "replacement": "envctl_migration_artifacts plus envctl_migration_evidence, envctl_migration_graph_edges, and envctl_migration_validations.",
+            "owner": "envctl-db-agent",
+            "risk": "medium",
+            "validation": "REQ-024 registry proof and generated DB model report are linked.",
+            "evidence_refs": [
+                "generated/envctl_migration_db_model.json",
+                "proof_records/REQ-024_ENVCTL_ARTIFACT_REGISTRY.proof.json",
+            ],
+        },
+        {
+            "component_id": "hardcoded-flexnetos-lifeos-paths",
+            "component": "Hardcoded FlexNetOS/lifeos comparison paths in prior prompts",
+            "classification": "replaced",
+            "disposition": "Replace with target descriptor driven roots and safety policy.",
+            "rationale": "The target descriptor records primary_root, compare_root, include/exclude rules, safety mode, collectors, contract, and recipe metadata.",
+            "replacement": "migration-artifacts/_meta/flexnetos-vs-lifeos.target-descriptor.yaml and envctl target registry rows.",
+            "owner": "target-registry-agent",
+            "risk": "medium",
+            "validation": "REQ-200 target descriptor proof validates descriptor fields and path policy.",
+            "evidence_refs": [
+                "migration-artifacts/_meta/flexnetos-vs-lifeos.target-descriptor.yaml",
+                "generated/flexnetos_target_descriptor_validation_report.json",
+            ],
+        },
+        {
+            "component_id": "external-background-scan-helper",
+            "component": "source/codex-flexnetos-migration-prompt-package/helpers/background_scan.sh",
+            "classification": "wrapped",
+            "disposition": "Keep as an external collector operation during adapter MVP, then replace gradually where native collectors are practical.",
+            "rationale": "The strategy decision preserves immediate continuity through the adapter while Phase G replaces shell helper behavior with native collectors.",
+            "replacement": "envctl operation records that execute/import helper output, followed by native collector implementations.",
+            "owner": "flexnetos-adapter-agent",
+            "risk": "medium",
+            "validation": "Adapter duties require importing package outputs as operations, evidence, artifacts, and graph links.",
+            "evidence_refs": [
+                "prompts/STRATEGY_DECISION.md",
+                "prompts/UTILIZE_FLEXNETOS_PACKAGE.md",
+                "prompts/IMPLEMENTATION_PHASES.md",
+            ],
+        },
+        {
+            "component_id": "codex-exec-runtime",
+            "component": "codex CLI background shell execution",
+            "classification": "wrapped",
+            "disposition": "Run through execution packets and envctl operation metadata instead of treating raw stdout as the state boundary.",
+            "rationale": issues.get("ART105-INCOMPAT-002", {}).get(
+                "finding",
+                "Execution packets require codex, python3, and shell tools supplied by the envctl runtime.",
+            ),
+            "replacement": "envctl run ledger, operation records, event/evidence hashes, and proof records.",
+            "owner": "envctl-runner-agent",
+            "risk": "medium",
+            "validation": "Packet, run ledger, and proof records link the runtime to replayable state.",
+            "evidence_refs": [
+                "generated/execution_packets/ART-133_DEPRECATION_MAP.json",
+                "generated/envctl_run_ledger_report.json",
+                "proof_records/REQ-022_ENVCTL_RUN_LEDGER.proof.json",
+            ],
+        },
+        {
+            "component_id": "prior-flexnetos-package-contract",
+            "component": "codex-flexnetos-migration-prompt-package artifact contract",
+            "classification": "preserved",
+            "disposition": "Preserve as the first external package fixture and acceptance contract.",
+            "rationale": "The strategy decision locks the prior artifact contract first and uses the bundled package as the concrete truth test.",
+            "replacement": "No replacement; import into envctl contracts and recipes.",
+            "owner": "artifact-agent",
