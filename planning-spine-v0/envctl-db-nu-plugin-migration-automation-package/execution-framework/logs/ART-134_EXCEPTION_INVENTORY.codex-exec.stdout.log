USAGE
}

ENVCTL_REPO=""
NU_PLUGIN_REPO=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --envctl-repo) ENVCTL_REPO="${2:?}"; shift 2 ;;
    --nu-plugin-repo) NU_PLUGIN_REPO="${2:?}"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
