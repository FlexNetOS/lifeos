+        (
+            "art-136-tech-debt-ledger-md",
+            "ART-136 Technical Debt Ledger Markdown",
+            "task_markdown_companion",
+            TASK_MD,
+        ),
+        (
+            "art-136-tech-debt-ledger-json",
