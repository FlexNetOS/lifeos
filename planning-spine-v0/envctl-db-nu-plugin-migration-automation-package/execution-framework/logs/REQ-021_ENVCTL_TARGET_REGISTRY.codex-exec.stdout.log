def indexes(conn: sqlite3.Connection, table: str) -> list[dict]:
    result = []
    for row in conn.execute(f"PRAGMA index_list({table})"):
        index_name = row[1]
        result.append(
            {
                "name": index_name,
                "unique": bool(row[2]),
                "origin": row[3],
                "partial": bool(row[4]),
                "columns": [col[2] for col in conn.execute(f"PRAGMA index_info({index_name})")],
            }
        )
    return result


