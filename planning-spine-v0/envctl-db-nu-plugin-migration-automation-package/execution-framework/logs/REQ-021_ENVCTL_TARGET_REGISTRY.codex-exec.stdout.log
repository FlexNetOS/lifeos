+
+
+def main() -> None:
+    base = package_root()
+    model = build_registry_model()
+    report = {
+        "schema_version": "1.0",
+        "task_id": TASK_ID,
+        "status": model["status"],
+        "generated_at": model["generated_at"],
+        "summary": model["summary"],
+        "errors": model["errors"],
