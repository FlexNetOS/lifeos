+              (id, run_id, operation_id, uri, evidence_kind, sha256, redacted, metadata_json)
+            VALUES (?, ?, ?, ?, ?, ?, ?, ?)
+            """,
+            (
+                evidence_id,
+                run_id,
+                operation_id,
+                uri,
+                evidence_kind,
+                sha256,
+                1 if redacted else 0,
+                canonical_json(metadata or {}),
+            ),
