+    )
+    ledger.append_event(
+        run_id=run["run_id"],
+        event_type="proof_linked",
+        phase="02-envctl-db",
+        actor_type="system",
+        actor_id="run-ledger",
+        operation_id="op-req022-run-ledger",
+        evidence_refs=[proof_link["uri"]],
