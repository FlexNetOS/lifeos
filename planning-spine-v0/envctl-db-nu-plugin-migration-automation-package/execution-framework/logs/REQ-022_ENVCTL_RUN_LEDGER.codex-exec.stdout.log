+    for event in report["ledger"]["snapshot"]["timeline"]:
+        lines.append(
+            "| {event_seq} | `{event_type}` | `{actor_type}` | `{operation_id}` | `{operation_status}` |".format(
+                **{key: "" if value is None else value for key, value in event.items()}
