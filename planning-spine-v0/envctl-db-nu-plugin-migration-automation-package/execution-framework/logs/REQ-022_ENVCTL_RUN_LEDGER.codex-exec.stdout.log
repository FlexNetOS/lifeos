+    def set_run_status(self, run_id: str, status: str) -> None:
+        self._require("run_status", status, RUN_STATUSES)
+        completed_at = now() if status in {"completed", "failed", "blocked", "cancelled", "denied"} else None
+        self.conn.execute(
+            """
