+        payload={"status": "completed", "next_unblocked": "REQ-027_ENVCTL_REPLAY_ENGINE"},
+    )
+
+    rejected_duplicate = False
+    rejected_invalid_status = False
+    try:
+        ledger.append_event(
+            run_id=run["run_id"],
