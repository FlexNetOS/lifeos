+                completed_at_utc = COALESCE(?, completed_at_utc)
+            WHERE id = ?
+            """,
+            (
+                status,
+                output_ref,
+                canonical_json(error) if error else None,
+                started_at,
+                completed_at,
+                operation_id,
+            ),
+        )
+        if cursor.rowcount != 1:
+            raise LedgerError(f"unknown operation: {operation_id}")
+        self.conn.commit()
+
