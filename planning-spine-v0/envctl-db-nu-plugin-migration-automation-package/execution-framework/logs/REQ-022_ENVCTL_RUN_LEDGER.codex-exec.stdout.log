+
+def proof_sha(relpath: str) -> str | None:
+    path = root() / relpath
+    if not path.exists():
+        return None
+    return "sha256:" + sha256_file(path)
+
+
+def exercise_ledger(conn: sqlite3.Connection) -> dict:
+    ledger = RunLedger(conn)
