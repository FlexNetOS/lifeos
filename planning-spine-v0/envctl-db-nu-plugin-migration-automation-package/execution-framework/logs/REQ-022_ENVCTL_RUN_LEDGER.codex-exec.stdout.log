+            phase="02-envctl-db",
+            status="ready",
+            risk="R1",
+            idempotency_key="REQ-022/persist-run-ledger",
+            command_redacted="python3 scripts/verify_envctl_run_ledger.py",
+            input={
+                "schemas": [
+                    "schemas/run_event.schema.json",
+                    "schemas/operation.schema.json",
+                ],
+                "tables": [
+                    "envctl_migration_runs",
