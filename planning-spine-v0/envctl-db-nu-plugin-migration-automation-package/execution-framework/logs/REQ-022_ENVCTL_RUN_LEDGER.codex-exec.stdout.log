+                op.run_id,
+                op.parent_operation_id,
+                op.operation_type,
+                op.phase,
+                op.status,
+                op.risk,
+                op.idempotency_key,
+                command_hash,
+                op.command_redacted,
+                canonical_json(op.input or {}),
+                op.output_ref,
+                canonical_json(op.error) if op.error else None,
+            ),
+        )
+        self.conn.commit()
+        return {
+            "operation_id": op.operation_id,
+            "run_id": op.run_id,
+            "status": op.status,
+            "risk": op.risk,
+            "command_hash": command_hash,
+        }
+
+    def set_operation_status(
+        self,
+        operation_id: str,
+        status: str,
+        *,
+        output_ref: str | None = None,
