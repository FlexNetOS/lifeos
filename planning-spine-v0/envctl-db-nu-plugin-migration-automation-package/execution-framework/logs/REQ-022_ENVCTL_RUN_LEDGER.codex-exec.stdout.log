+        )
+    (root() / "docs" / "ENVCTL_RUN_LEDGER.md").write_text("\n".join(lines) + "\n", encoding="utf-8")
+
+
+def main() -> None:
+    base = package_root()
+    conn = sqlite3.connect(":memory:")
