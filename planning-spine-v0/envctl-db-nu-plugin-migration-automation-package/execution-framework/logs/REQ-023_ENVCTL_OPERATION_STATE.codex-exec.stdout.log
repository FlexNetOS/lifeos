   196	def normalize_state(value: str | OperationState) -> OperationState:
   197	    if isinstance(value, OperationState):
   198	        return value
   199	    normalized = value.replace("-", "_")
   200	    for state in OperationState:
   201	        if normalized == state.value:
   202	            return state
   203	    if value in STATE_BY_DB_STATUS:
   204	        return STATE_BY_DB_STATUS[value]
   205	    raise OperationTransitionError(f"unknown operation state/status: {value}")
