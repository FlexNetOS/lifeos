   229	            f"illegal operation transition: {record.state.value} -> {target.value}"
   230	        )
   231	
   232	    if trigger == "start" and approval_required(record.risk) and record.state != OperationState.APPROVED:
   233	        raise OperationTransitionError(
   234	            f"risk {record.risk} operation requires approved state before running"
   235	        )
   236	
   237	    next_record = OperationRecord(
   238	        operation_id=record.operation_id,
   239	        run_id=record.run_id,
   240	        operation_type=record.operation_type,
   241	        state=target,
   242	        risk=record.risk,
   243	    )
   244	    result = TransitionResult(
   245	        operation_id=record.operation_id,
   246	        run_id=record.run_id,
   247	        operation_type=record.operation_type,
   248	        previous_state=record.state.value,
   249	        state=target.value,
   250	        trigger=trigger,
   251	        risk=record.risk,
   252	        db_status=DB_STATUS_BY_STATE[target],
   253	        event_type=f"operation_{target.value}",
   254	        terminal=target in TERMINAL_STATES,
   255	        reason=reason,
   256	    )
   257	    return next_record, result
