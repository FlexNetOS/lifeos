+from __future__ import annotations
+
+import fnmatch
+import hashlib
+import json
+import sqlite3
+from dataclasses import dataclass, field
+from pathlib import Path
+from typing import Any
+
+from _common import package_root
+
+
+ALLOWED_STATUSES = {"complete", "partial", "unknown", "blocked"}
+VALIDATION_STATUSES = {"pass", "fail", "warn", "blocked", "unknown"}
+BLOCKED_PATH_PATTERNS = ("**/.env", "**/secrets/**", "**/private_keys/**", "**/*.pem", "**/*.key")
+
+
+class ArtifactRegistryError(ValueError):
+    """Raised when an artifact record cannot be safely persisted."""
+
+
+def _stable_id(prefix: str, *parts: str) -> str:
+    digest = hashlib.sha256("\x1f".join(parts).encode("utf-8")).hexdigest()[:20]
+    return f"{prefix}-{digest}"
+
+
+def _json_dumps(value: Any) -> str:
+    return json.dumps(value, sort_keys=True, separators=(",", ":"))
+
+
+def _json_loads(value: str | None, fallback: Any) -> Any:
+    if value is None or value == "":
+        return fallback
+    return json.loads(value)
+
+
+def _sha256_file(path: Path) -> str:
+    digest = hashlib.sha256()
+    with path.open("rb") as handle:
+        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
+            digest.update(chunk)
+    return f"sha256:{digest.hexdigest()}"
+
+
+@dataclass(frozen=True)
+class ArtifactRecord:
+    artifact_id: str
+    run_id: str
+    title: str
+    status: str
+    artifact_type: str | None = None
+    path: str | None = None
+    content_hash: str | None = None
+    generated_by_operation_id: str | None = None
+    contract_id: str | None = None
+    provenance: dict[str, Any] = field(default_factory=dict)
+    evidence_refs: list[str] = field(default_factory=list)
+    links: list[dict[str, str]] = field(default_factory=list)
+    validation_refs: list[str] = field(default_factory=list)
+
+    @classmethod
+    def from_mapping(cls, value: dict[str, Any]) -> "ArtifactRecord":
+        return cls(
+            artifact_id=str(value["artifact_id"]),
+            run_id=str(value["run_id"]),
+            title=str(value["title"]),
+            status=str(value["status"]),
+            artifact_type=value.get("artifact_type"),
+            path=value.get("path"),
+            content_hash=value.get("content_hash"),
+            generated_by_operation_id=value.get("generated_by_operation_id") or value.get("producer_operation_id"),
+            contract_id=value.get("contract_id"),
+            provenance=dict(value.get("provenance") or {}),
+            evidence_refs=list(value.get("evidence_refs") or []),
+            links=list(value.get("links") or []),
+            validation_refs=list(value.get("validation_refs") or []),
+        )
+
+    def schema_record(self, content_hash: str | None = None) -> dict[str, Any]:
+        return {
+            "artifact_id": self.artifact_id,
+            "run_id": self.run_id,
+            "title": self.title,
+            "status": self.status,
+            "artifact_type": self.artifact_type,
+            "path": self.path,
+            "content_hash": content_hash if content_hash is not None else self.content_hash,
+            "evidence_refs": list(self.evidence_refs),
+            "links": list(self.links),
+        }
+
+
+class ArtifactRegistry:
+    def __init__(self, conn: sqlite3.Connection, base_path: Path | None = None) -> None:
+        self.conn = conn
+        self.base_path = base_path or package_root()
+
+    def register_artifact(self, record: ArtifactRecord) -> dict[str, Any]:
+        content_hash = self._validate_artifact(record)
+        evidence_payload = {
+            "contract_id": record.contract_id,
+            "provenance": record.provenance,
+            "evidence_refs": record.evidence_refs,
+            "validation_refs": record.validation_refs,
+        }
+        row_id = _stable_id("artifact", record.run_id, record.artifact_id)
+        self.conn.execute(
+            """
+            INSERT INTO envctl_migration_artifacts
+              (id, run_id, artifact_id, title, artifact_type, status, path,
+               content_hash, generated_by_operation_id, evidence_json, links_json)
+            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
+            ON CONFLICT(run_id, artifact_id) DO UPDATE SET
+              title = excluded.title,
+              artifact_type = excluded.artifact_type,
+              status = excluded.status,
+              path = excluded.path,
+              content_hash = excluded.content_hash,
+              generated_by_operation_id = excluded.generated_by_operation_id,
+              evidence_json = excluded.evidence_json,
+              links_json = excluded.links_json,
+              updated_at_utc = strftime('%Y-%m-%dT%H:%M:%fZ','now')
+            """,
+            (
+                row_id,
+                record.run_id,
+                record.artifact_id,
+                record.title,
+                record.artifact_type,
+                record.status,
+                record.path,
+                content_hash,
+                record.generated_by_operation_id,
+                _json_dumps(evidence_payload),
+                _json_dumps(record.links),
+            ),
+        )
+        for link in record.links:
+            self._upsert_graph_link(record, link)
+        self.conn.commit()
+        return self.get_artifact(record.run_id, record.artifact_id)
+
+    def register_validation(
+        self,
+        *,
+        validation_id: str,
+        run_id: str,
+        artifact_id: str,
+        operation_id: str | None,
+        validator: str,
+        status: str,
+        details: dict[str, Any] | None = None,
+        evidence_refs: list[str] | None = None,
+    ) -> dict[str, Any]:
+        if status not in VALIDATION_STATUSES:
+            raise ArtifactRegistryError(f"invalid validation status: {status}")
+        self._require_run(run_id)
+        self._require_artifact(run_id, artifact_id)
+        if operation_id is not None:
+            self._require_operation(run_id, operation_id)
+        refs = evidence_refs or []
+        self._require_evidence_refs(run_id, refs)
+        self.conn.execute(
+            """
+            INSERT INTO envctl_migration_validations
+              (id, run_id, artifact_id, operation_id, validator, status, details_json, evidence_json)
+            VALUES (?, ?, ?, ?, ?, ?, ?, ?)
+            ON CONFLICT(id) DO UPDATE SET
+              run_id = excluded.run_id,
+              artifact_id = excluded.artifact_id,
+              operation_id = excluded.operation_id,
+              validator = excluded.validator,
+              status = excluded.status,
+              details_json = excluded.details_json,
+              evidence_json = excluded.evidence_json
+            """,
+            (
+                validation_id,
+                run_id,
+                artifact_id,
+                operation_id,
+                validator,
+                status,
+                _json_dumps(details or {}),
+                _json_dumps(refs),
+            ),
+        )
+        self._append_validation_ref(run_id, artifact_id, validation_id)
+        self.conn.commit()
+        return {
+            "validation_id": validation_id,
+            "run_id": run_id,
+            "artifact_id": artifact_id,
+            "validator": validator,
+            "status": status,
+        }
+
+    def get_artifact(self, run_id: str, artifact_id: str) -> dict[str, Any]:
+        row = self.conn.execute(
+            """
+            SELECT id, run_id, artifact_id, title, artifact_type, status, path,
+                   content_hash, generated_by_operation_id, evidence_json, links_json
+            FROM envctl_migration_artifacts
+            WHERE run_id = ? AND artifact_id = ?
+            """,
+            (run_id, artifact_id),
+        ).fetchone()
+        if row is None:
+            raise ArtifactRegistryError(f"artifact not found: {run_id}/{artifact_id}")
+        evidence_payload = _json_loads(row[9], {})
+        links = _json_loads(row[10], [])
+        return {
+            "id": row[0],
+            "artifact_id": row[2],
+            "run_id": row[1],
+            "title": row[3],
+            "artifact_type": row[4],
+            "status": row[5],
+            "path": row[6],
+            "content_hash": row[7],
+            "generated_by_operation_id": row[8],
+            "contract_id": evidence_payload.get("contract_id"),
+            "provenance": evidence_payload.get("provenance") or {},
+            "evidence_refs": evidence_payload.get("evidence_refs") or [],
+            "validation_refs": evidence_payload.get("validation_refs") or [],
+            "links": links,
+        }
+
+    def export_schema_record(self, run_id: str, artifact_id: str) -> dict[str, Any]:
+        artifact = self.get_artifact(run_id, artifact_id)
+        return {
+            "artifact_id": artifact["artifact_id"],
+            "run_id": artifact["run_id"],
+            "title": artifact["title"],
+            "status": artifact["status"],
+            "artifact_type": artifact["artifact_type"],
+            "path": artifact["path"],
+            "content_hash": artifact["content_hash"],
+            "evidence_refs": artifact["evidence_refs"],
+            "links": artifact["links"],
+        }
+
+    def _validate_artifact(self, record: ArtifactRecord) -> str | None:
+        for field_name in ("artifact_id", "run_id", "title", "status"):
+            if not getattr(record, field_name):
+                raise ArtifactRegistryError(f"missing required artifact field: {field_name}")
+        if record.status not in ALLOWED_STATUSES:
+            raise ArtifactRegistryError(f"invalid artifact status: {record.status}")
+        if not isinstance(record.provenance, dict):
+            raise ArtifactRegistryError("provenance must be an object")
+        if not isinstance(record.evidence_refs, list) or not all(isinstance(ref, str) for ref in record.evidence_refs):
+            raise ArtifactRegistryError("evidence_refs must be a string array")
+        if not isinstance(record.validation_refs, list) or not all(isinstance(ref, str) for ref in record.validation_refs):
+            raise ArtifactRegistryError("validation_refs must be a string array")
+        for link in record.links:
+            if not isinstance(link, dict) or not link.get("to") or not link.get("type"):
+                raise ArtifactRegistryError("each link must include non-empty 'to' and 'type'")
+        self._require_run(record.run_id)
+        if record.generated_by_operation_id is not None:
+            self._require_operation(record.run_id, record.generated_by_operation_id)
+        if record.contract_id is not None:
+            self._require_contract_for_run(record.run_id, record.contract_id)
+        self._require_evidence_refs(record.run_id, record.evidence_refs)
+        return self._validate_path_and_hash(record.path, record.content_hash)
+
+    def _validate_path_and_hash(self, relpath: str | None, content_hash: str | None) -> str | None:
+        if relpath is None:
+            return content_hash
+        normalized = relpath.replace("\\", "/")
+        if normalized.startswith("/") or ".." in Path(normalized).parts:
+            raise ArtifactRegistryError(f"artifact path must stay package-relative: {relpath}")
+        for pattern in BLOCKED_PATH_PATTERNS:
+            if fnmatch.fnmatch(normalized, pattern) or fnmatch.fnmatch(f"root/{normalized}", pattern):
+                raise ArtifactRegistryError(f"artifact path is blocked by policy: {relpath}")
+        path = self.base_path / normalized
+        if not path.exists():
+            return content_hash
+        if not path.is_file():
+            raise ArtifactRegistryError(f"artifact path is not a file: {relpath}")
+        actual_hash = _sha256_file(path)
+        if content_hash is not None and content_hash != actual_hash:
+            raise ArtifactRegistryError(f"content hash mismatch for {relpath}")
+        return actual_hash
+
+    def _require_run(self, run_id: str) -> None:
+        exists = self.conn.execute("SELECT 1 FROM envctl_migration_runs WHERE id = ?", (run_id,)).fetchone()
+        if exists is None:
+            raise ArtifactRegistryError(f"unknown run_id: {run_id}")
+
+    def _require_artifact(self, run_id: str, artifact_id: str) -> None:
+        exists = self.conn.execute(
+            "SELECT 1 FROM envctl_migration_artifacts WHERE run_id = ? AND artifact_id = ?",
+            (run_id, artifact_id),
+        ).fetchone()
+        if exists is None:
+            raise ArtifactRegistryError(f"unknown artifact_id for run: {run_id}/{artifact_id}")
+
+    def _require_operation(self, run_id: str, operation_id: str) -> None:
+        exists = self.conn.execute(
+            "SELECT 1 FROM envctl_migration_operations WHERE run_id = ? AND id = ?",
+            (run_id, operation_id),
+        ).fetchone()
+        if exists is None:
+            raise ArtifactRegistryError(f"operation does not belong to run: {operation_id}")
+
+    def _require_contract_for_run(self, run_id: str, contract_id: str) -> None:
+        row = self.conn.execute(
+            "SELECT artifact_contract_id FROM envctl_migration_runs WHERE id = ?",
+            (run_id,),
+        ).fetchone()
+        if row is None:
+            raise ArtifactRegistryError(f"unknown run_id: {run_id}")
+        if row[0] != contract_id:
+            raise ArtifactRegistryError(f"contract_id does not match run contract: {contract_id}")
+        exists = self.conn.execute(
+            "SELECT 1 FROM envctl_migration_artifact_contracts WHERE id = ?",
+            (contract_id,),
+        ).fetchone()
+        if exists is None:
+            raise ArtifactRegistryError(f"unknown contract_id: {contract_id}")
+
+    def _require_evidence_refs(self, run_id: str, evidence_refs: list[str]) -> None:
+        for ref in evidence_refs:
+            exists = self.conn.execute(
+                "SELECT 1 FROM envctl_migration_evidence WHERE run_id = ? AND id = ?",
+                (run_id, ref),
+            ).fetchone()
+            if exists is None:
+                raise ArtifactRegistryError(f"unknown evidence ref for run: {ref}")
+
+    def _upsert_graph_link(self, record: ArtifactRecord, link: dict[str, str]) -> None:
+        edge_id = _stable_id("edge", record.run_id, record.artifact_id, link["type"], link["to"])
