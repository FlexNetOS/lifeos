+        actor="codex-cli-local",
+        helper_id=HELPER_ID,
+        model_tag=MODEL_TAG,
+        repo_path=str(package_root()),
+        files_changed=files_changed,
+        commands_run=["python3 scripts/verify_artifact_registry.py"],
+        verification_output={
+            "schema_version": report["schema_version"],
+            "task_id": TASK_ID,
+            "status": report["status"],
+            "summary": report["summary"],
+            "checks": report["checks"],
+            "errors": report["errors"],
+            "evidence": report["evidence"],
+        },
+        evidence=report["evidence"],
+        next_action="artifact-producing ART-* tasks can register generated outputs through scripts/artifact_registry.py",
+    )
+    append_proof(proof)
+    print(json.dumps({"task_id": TASK_ID, "status": "passed", "summary": report["summary"]}, indent=2))
