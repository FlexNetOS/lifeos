+    ]
+    proof = make_proof(
+        TASK_ID,
+        "completed" if report["status"] == "passed" else "failed",
+        "codex-cli-local",
+        HELPER_ID,
+        MODEL_TAG,
+        str(base),
+        files_changed,
+        commands_run,
+        report,
