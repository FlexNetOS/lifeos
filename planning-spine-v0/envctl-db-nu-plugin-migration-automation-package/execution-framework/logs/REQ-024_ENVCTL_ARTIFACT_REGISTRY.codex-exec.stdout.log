+        "" if report["status"] == "passed" else "; ".join(report["errors"]),
+        "run ART-100_SYSTEM_INVENTORY with artifact registry writes" if report["status"] == "passed" else "fix artifact registry verification errors",
+    )
+    append_proof(proof)
+    print(
