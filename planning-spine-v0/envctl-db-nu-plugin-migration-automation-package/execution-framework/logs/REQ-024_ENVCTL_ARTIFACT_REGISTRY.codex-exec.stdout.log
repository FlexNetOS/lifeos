+++ b/envctl-db-nu-plugin-migration-automation-package/execution-framework/scripts/verify_artifact_registry.py
@@ -0,0 +1,317 @@
+from __future__ import annotations
+
+import json
+import sqlite3
+from pathlib import Path
+from typing import Any
+
+from _common import append_proof, make_proof, now, package_root, root, sha256_file, write_json
+from artifact_registry import ArtifactRecord, ArtifactRegistry, ArtifactRegistryError
+from verify_envctl_db_schema import apply_migrations, insert_lifecycle_fixture
+
+
+TASK_ID = "REQ-024_ENVCTL_ARTIFACT_REGISTRY"
+HELPER_ID = "helper-envctl-artifacts-01"
+MODEL_TAG = "gpt-5.3-spark"
+
+
+def load_json(path: Path) -> dict[str, Any]:
+    return json.loads(path.read_text(encoding="utf-8"))
+
+
+def validate_schema_shape(schema: dict[str, Any], record: dict[str, Any]) -> list[str]:
+    errors: list[str] = []
+    for key in schema.get("required", []):
+        if key not in record or record[key] in (None, ""):
+            errors.append(f"missing required key: {key}")
+    properties = schema.get("properties", {})
+    status_enum = properties.get("status", {}).get("enum")
+    if status_enum and record.get("status") not in status_enum:
+        errors.append(f"status not in schema enum: {record.get('status')}")
+    if not isinstance(record.get("evidence_refs"), list):
+        errors.append("evidence_refs is not an array")
+    links = record.get("links")
+    if not isinstance(links, list):
+        errors.append("links is not an array")
+    else:
+        for index, link in enumerate(links):
+            if not isinstance(link, dict) or not link.get("to") or not link.get("type"):
+                errors.append(f"link {index} does not include to/type")
+    return errors
+
+
+def expect_registry_error(label: str, fn) -> dict[str, str]:
+    try:
+        fn()
+    except ArtifactRegistryError as exc:
+        return {"case": label, "rejected": "true", "error": str(exc)}
+    raise AssertionError(f"{label} was accepted")
+
+
+def build_registry_report() -> dict[str, Any]:
+    base = package_root()
+    schema_path = base / "schemas" / "artifact_record.schema.json"
+    expected_artifacts_path = base / "expected-output" / "migration-automation-artifacts.md"
+    schema = load_json(schema_path)
+
+    conn = sqlite3.connect(":memory:")
+    conn.execute("PRAGMA foreign_keys = ON")
+    applied = apply_migrations(conn, base)
+    fixture = insert_lifecycle_fixture(conn)
+    registry = ArtifactRegistry(conn, base_path=base)
+
+    artifact_hash = sha256_file(expected_artifacts_path)
+    artifact = ArtifactRecord(
+        artifact_id="migration-automation-artifacts",
+        run_id=fixture["run_id"],
+        title="Expected migration automation artifacts",
+        status="complete",
+        artifact_type="artifact_registry",
+        path="expected-output/migration-automation-artifacts.md",
+        content_hash=f"sha256:{artifact_hash}",
+        generated_by_operation_id=fixture["operation_id"],
+        contract_id="contract-req020",
+        provenance={
+            "task_id": TASK_ID,
+            "producer": "envctl-db-agent",
+            "source_schema": "schemas/artifact_record.schema.json",
+            "source_expected_output": "expected-output/migration-automation-artifacts.md",
+        },
+        evidence_refs=["evidence-req020"],
+        links=[
+            {"to": "contract:contract-req020", "type": "satisfies_contract"},
+            {"to": "operation:op-req020", "type": "produced_by"},
+            {"to": "artifact:envctl-db-schema-model", "type": "derived_from"},
+        ],
+    )
+    persisted = registry.register_artifact(artifact)
+    hash_validation = registry.register_validation(
+        validation_id="validation-req024-hash",
+        run_id=artifact.run_id,
+        artifact_id=artifact.artifact_id,
+        operation_id=fixture["operation_id"],
+        validator="verify_artifact_registry.py::hash",
+        status="pass",
+        details={"path": artifact.path, "content_hash": persisted["content_hash"]},
+        evidence_refs=["evidence-req020"],
+    )
+    schema_validation = registry.register_validation(
+        validation_id="validation-req024-schema",
+        run_id=artifact.run_id,
+        artifact_id=artifact.artifact_id,
+        operation_id=fixture["operation_id"],
+        validator="verify_artifact_registry.py::schema",
+        status="pass",
+        details={"schema": "schemas/artifact_record.schema.json"},
+        evidence_refs=["evidence-req020"],
+    )
+    persisted = registry.get_artifact(artifact.run_id, artifact.artifact_id)
+    exported = registry.export_schema_record(artifact.run_id, artifact.artifact_id)
+    schema_errors = validate_schema_shape(schema, exported)
+    if schema_errors:
+        raise AssertionError("; ".join(schema_errors))
+
+    index_row = conn.execute(
+        """
+        SELECT artifact_id, title, status, path, content_hash
+        FROM envctl_migration_artifact_index
+        WHERE run_id = ? AND artifact_id = ?
+        """,
+        (artifact.run_id, artifact.artifact_id),
+    ).fetchone()
+    if index_row is None:
+        raise AssertionError("artifact index view did not expose registered artifact")
+
+    edge_count = conn.execute(
+        """
+        SELECT COUNT(*)
+        FROM envctl_migration_graph_edges
+        WHERE run_id = ? AND source_artifact_id = ?
+        """,
+        (artifact.run_id, artifact.artifact_id),
+    ).fetchone()[0]
+    if edge_count != len(artifact.links):
+        raise AssertionError(f"expected {len(artifact.links)} graph links, found {edge_count}")
+
+    validation_refs = registry.get_artifact(artifact.run_id, artifact.artifact_id)["validation_refs"]
+    for validation_id in (hash_validation["validation_id"], schema_validation["validation_id"]):
+        if validation_id not in validation_refs:
+            raise AssertionError(f"missing validation link: {validation_id}")
+
+    rejection_cases = [
+        expect_registry_error(
+            "blocked secret path",
+            lambda: registry.register_artifact(
+                ArtifactRecord(
+                    artifact_id="blocked-secret",
+                    run_id=fixture["run_id"],
+                    title="Blocked secret path",
+                    status="complete",
+                    path="repo/secrets/token.txt",
+                    generated_by_operation_id=fixture["operation_id"],
+                )
+            ),
+        ),
+        expect_registry_error(
+            "mismatched content hash",
+            lambda: registry.register_artifact(
+                ArtifactRecord(
+                    artifact_id="bad-hash",
+                    run_id=fixture["run_id"],
+                    title="Bad hash",
+                    status="complete",
+                    path="expected-output/migration-automation-artifacts.md",
+                    content_hash="sha256:bad",
+                    generated_by_operation_id=fixture["operation_id"],
+                )
+            ),
+        ),
+        expect_registry_error(
+            "foreign producer operation",
+            lambda: registry.register_artifact(
+                ArtifactRecord(
+                    artifact_id="bad-producer",
+                    run_id=fixture["run_id"],
+                    title="Bad producer",
+                    status="complete",
+                    generated_by_operation_id="op-does-not-exist",
+                )
+            ),
+        ),
+    ]
+
+    artifact_count = conn.execute(
+        "SELECT COUNT(*) FROM envctl_migration_artifacts WHERE run_id = ?",
+        (fixture["run_id"],),
+    ).fetchone()[0]
+    validation_count = conn.execute(
+        "SELECT COUNT(*) FROM envctl_migration_validations WHERE run_id = ? AND artifact_id = ?",
+        (fixture["run_id"], artifact.artifact_id),
+    ).fetchone()[0]
+
+    return {
+        "schema_version": "1.0",
+        "task_id": TASK_ID,
+        "status": "passed",
+        "generated_at": now(),
