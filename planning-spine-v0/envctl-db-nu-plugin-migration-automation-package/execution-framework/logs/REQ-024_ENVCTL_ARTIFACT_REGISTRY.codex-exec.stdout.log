   246	    if index_row is None:
   247	        errors.append("artifact did not appear in envctl_migration_artifact_index")
   248	    if "Artifact registry" not in expected:
   249	        errors.append("expected-output artifact list does not include Artifact registry")
   250	    required = set(schema.get("required", []))
