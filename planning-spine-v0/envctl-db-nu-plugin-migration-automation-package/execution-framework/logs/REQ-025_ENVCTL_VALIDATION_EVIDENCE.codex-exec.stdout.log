+        },
+        {
+            "validation_id": "validation-req025-tests",
+            "run_id": fixture["run_id"],
+            "operation_id": fixture["operation_id"],
+            "validator": "validation_evidence.py:test-results",
+            "status": "pass",
+            "details": {"command": "python3 scripts/verify_validation_evidence.py"},
+            "evidence_refs": [
