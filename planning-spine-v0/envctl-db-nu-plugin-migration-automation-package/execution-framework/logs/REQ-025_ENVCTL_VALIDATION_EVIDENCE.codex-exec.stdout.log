+            "operation_id": fixture["operation_id"],
+            "validator": "validation_evidence.py:parity",
+            "status": "warn",
+            "details": {"source": "envctl", "target": "nu_plugin", "pending": ["ART-132_PARITY_DASHBOARD"]},
+            "evidence_refs": [
