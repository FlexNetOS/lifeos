+            SET status = 'approved', decided_by = ?, reason = COALESCE(NULLIF(?, ''), reason),
+                decided_at_utc = strftime('%Y-%m-%dT%H:%M:%fZ','now')
+            WHERE status = 'open' AND reason LIKE ?
