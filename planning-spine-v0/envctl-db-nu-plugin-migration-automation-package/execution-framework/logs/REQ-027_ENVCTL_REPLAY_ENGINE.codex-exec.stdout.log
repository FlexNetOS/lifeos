+REPLAY_MODES = {"dry_run", "apply"}
+BLOCKED_REF_PARTS = {".env", "secrets", "private_keys"}
+BLOCKED_REF_SUFFIXES = {".pem", ".key"}
+NON_DETERMINISTIC_OPERATION_TYPES = {
