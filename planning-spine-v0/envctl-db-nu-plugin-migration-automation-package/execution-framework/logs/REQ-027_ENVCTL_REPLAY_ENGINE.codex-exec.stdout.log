+
+    def _checkpoints(self, run_id: str, operation_ids: list[str]) -> list[dict[str, Any]]:
+        params: list[Any] = [run_id]
+        where = "run_id = ?"
+        if operation_ids:
+            where += " AND operation_id IN ({})".format(",".join("?" for _ in operation_ids))
+            params.extend(operation_ids)
