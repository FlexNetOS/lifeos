+    )
+    conn.execute(
+        """
+        INSERT INTO envctl_migration_recipes
+          (id, recipe_name, recipe_version, artifact_contract_id, recipe_hash, recipe_json)
+        VALUES (?, ?, ?, ?, ?, ?)
+        """,
+        (
+            recipe_id,
