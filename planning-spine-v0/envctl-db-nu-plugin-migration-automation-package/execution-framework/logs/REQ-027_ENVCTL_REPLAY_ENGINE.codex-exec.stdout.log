+                dry=report["replay"]["dry_run"]["status"],
+                apply=report["replay"]["apply_blocked"]["status"],
+                mismatch=report["replay"]["mismatch"]["status"],
+                approvals=len(report["replay"]["apply_blocked"]["required_approvals"]),
