+            )
+        )
+    else:
+        lines.append("No blockers.")
+    lines.extend(
+        [
+            "",
+            "## Graph Edges",
+            "",
+            *table(
+                ["from", "to", "type"],
+                [
+                    [edge["from"], edge["to"], edge["edge_type"]]
+                    for edge in model["task_graph"]["edges"][:50]
+                ],
+            ),
+            "",
+        ]
+    )
+    return "\n".join(lines)
+
