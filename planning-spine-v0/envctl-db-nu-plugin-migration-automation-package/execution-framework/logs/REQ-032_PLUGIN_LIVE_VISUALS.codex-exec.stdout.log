+    write_json("state/REQ-032_PLUGIN_LIVE_VISUALS.heartbeat.json", heartbeat)
+    log = {
+        "schema_version": "1.0",
+        "task_id": TASK_ID,
+        "status": "completed",
+        "generated_at": now(),
