+                "task_count": len(group_tasks),
+                "max_parallel": max_parallel,
+                "ready": counts["ready"],
+                "running_capacity": min(counts["ready"], max_parallel),
+                "completed": counts["completed"],
+                "pending": counts["pending"],
+                "blocked": counts["blocked"],
+                "failed": counts["failed"],
+            }
+        )
+
+    blocker_rows = [
