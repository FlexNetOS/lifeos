+            sorted(model["proof_state"]["task_proof_status_counts"].items()),
+        ),
+        "",
+        "## Blockers",
+        "",
+    ]
+    blocker_rows = model["blockers"][:30]
+    if blocker_rows:
+        lines.extend(
+            table(
