+{"operation_id":"op-safe","run_id":"run-7","operation_type":"scan","status":"ready","risk":"R1"}"#,
+        )
+        .unwrap();
+
+        let rows = envctl_human_approval_rows(
+            &approvals_path,
+            Some(&operations_path),
+            "approval-gated",
