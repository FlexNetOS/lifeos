                && matches!(value, Value::String { val, .. } if val == "structured_rows_ready")
        }));
        assert!(content.iter().any(|(key, value)| {
            *key == "structured_row_count" && matches!(value, Value::Int { val, .. } if *val >= 2)
        }));
