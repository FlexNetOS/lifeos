fn source_file_rows(repo_path: &Path, span: Span) -> Result<Vec<Row>, LabeledError> {
    scan_filesystem(repo_path)
        .map_err(scan_error)?
        .into_iter()
        .filter(|entry| entry.classification == FileClassification::RustSource)
        .map(|entry| filesystem_row(entry, span))
        .collect()
