++fn mode_requires_human(mode: &str) -> bool {
++    matches!(mode, "approval-gated" | "operator")
++}
++
++fn risk_requires_human(risk: &str) -> bool {
++    matches!(risk, "R3" | "R4" | "R5")
++}
