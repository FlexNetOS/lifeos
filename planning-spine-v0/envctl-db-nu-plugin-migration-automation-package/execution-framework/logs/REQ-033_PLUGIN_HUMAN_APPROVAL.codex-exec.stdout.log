+                "run_id":"run-7",
+                "operation_id":"op-risky",
+                "risk":"R4",
+                "status":"open",
+                "requested_by":"agent:planner",
+                "reason":"needs human sign-off"
+            }]"#,
+        )
+        .unwrap();
+        fs::write(
+            &operations_path,
