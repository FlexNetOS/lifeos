                    "owner":"yazelix",
                    "source_of_truth_class":"repo_source",
                    "file_kind":"regular_file",
                    "parser_hint":"toml",
                    "safety_policy":"source_content_import_allowed",
                    "reproduction_policy":"git_checkout",
