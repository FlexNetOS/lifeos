+def imported_schema(base: Path, def_name: str, relpath: str) -> dict:
+    schema = read_json(base, relpath)
+    schema = rewrite_internal_refs(schema, def_name)
+    schema.pop("$schema", None)
+    schema["x-shared-protocol-source"] = relpath
+    return schema
