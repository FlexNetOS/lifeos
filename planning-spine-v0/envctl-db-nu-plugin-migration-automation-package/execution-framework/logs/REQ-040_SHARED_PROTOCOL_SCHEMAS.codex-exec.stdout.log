+
+
+TASK_ID = "REQ-040_SHARED_PROTOCOL_SCHEMAS"
+HELPER_ID = "helper-shared-schema-01"
+MODEL_TAG = "gpt-5.3-spark"
+PROTOCOL_VERSION = "1.0.0"
