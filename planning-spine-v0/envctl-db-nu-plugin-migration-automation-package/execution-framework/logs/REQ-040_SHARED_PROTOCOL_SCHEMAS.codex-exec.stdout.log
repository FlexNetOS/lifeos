+            "Versioned record contracts shared by envctl's migration database "
+            "and the nu_plugin presentation/control surface."
+        ),
+        "oneOf": [{"$ref": f"#/$defs/{name}"} for name in REQUIRED_RECORDS],
+        "$defs": defs,
+    }
