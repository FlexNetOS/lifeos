+                "source_schema": schema_def.get("x-shared-protocol-source", "generated"),
+                "source_of_truth": table_map[name],
+                "producer": "envctl",
+                "consumer": "nu_plugin",
+                "plugin_shape": plugin_shapes[name],
+                "required": True,
+            }
+        )
+    return {
