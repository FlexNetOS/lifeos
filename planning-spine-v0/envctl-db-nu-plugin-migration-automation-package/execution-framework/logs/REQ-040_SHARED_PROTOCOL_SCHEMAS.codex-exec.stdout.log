+            "source_schema_count": source_schema_count,
+            "generated_schema_count": generated_schema_count,
+            "sample_validation_count": len(sample_results),
+        },
+        "sample_results": sample_results,
+        "errors": errors,
+        "evidence": manifest["generated_files"],
+    }
