+                            "operation_type": "nu_plugin.status.surface.refresh",
+                            "risk": "R4",
+                            "inputs": {"source": "REQ-034_PLUGIN_STATUS_STREAMS"},
+                            "expected_artifacts": ["req041-two-repo-report"],
+                            "validators": ["verify_two_repo_integration.py"],
+                            "rollback": None,
+                        },
+                    ],
+                }
+            ],
+            "metadata": {
