+            },
+            "collectors": {"db_schema": True, "plugin_surface": True},
+            "artifact_contract": {"name": "req022-run-ledger-contract", "version": "1.0.0"},
+            "recipe": {"name": "req022-run-ledger-recipe", "version": "1.0.0"},
