MIGRATION_FILES = [
    "sql/001_migration_automation_schema.sql",
    "sql/002_views_and_indexes.sql",
    "execution-framework/generated/contract_manifest.seed.sql",
]

RUN_STATUSES = {
    "created",
    "planning",
    "awaiting_approval",
    "running",
    "paused",
    "validating",
    "completed",
    "failed",
    "blocked",
    "cancelled",
