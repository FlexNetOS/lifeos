+        model_tag=MODEL_TAG,
+        repo_path=packet["repo_path"],
+        files_changed=[REPORT_PATH, DOC_PATH, HEARTBEAT_PATH, packet["proof_uri"]],
+        commands_run=[
+            "python3 scripts/verify_two_repo_integration.py",
