+            "max_auto_risk": "R4",
+            "reproducibility_hash": run_row["reproducibility_hash"],
+            "created_at_utc": run_row["started_at_utc"],
+            "updated_at_utc": run_row["completed_at_utc"],
+            "metadata": {"task_id": TASK_ID, "owner_lane": "lane_e_verification"},
+        },
