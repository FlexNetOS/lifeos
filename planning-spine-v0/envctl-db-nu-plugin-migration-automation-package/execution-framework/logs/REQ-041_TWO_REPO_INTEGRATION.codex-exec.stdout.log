+    insert_artifact_rows(conn, run["run_id"], gated_op["operation_id"])
+    ledger.set_run_status(run["run_id"], "completed")
+
+    return {
+        "conn": conn,
+        "applied_migrations": applied,
+        "run_id": run["run_id"],
