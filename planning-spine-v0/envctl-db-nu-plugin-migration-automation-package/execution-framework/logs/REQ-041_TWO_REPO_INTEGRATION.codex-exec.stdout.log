+def fetch_one(conn: sqlite3.Connection, sql: str, params: tuple[Any, ...]) -> sqlite3.Row:
+    row = conn.execute(sql, params).fetchone()
+    if row is None:
+        raise ValueError(f"query returned no rows: {sql}")
+    return row
