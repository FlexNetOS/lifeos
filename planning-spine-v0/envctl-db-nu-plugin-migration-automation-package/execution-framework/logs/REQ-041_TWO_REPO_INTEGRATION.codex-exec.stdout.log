+                    "generated/REQ-033_PLUGIN_HUMAN_APPROVAL.contract.json",
+                    "generated/REQ-034_PLUGIN_STATUS_STREAMS.contract.json",
+                ]
+            ),
+        ),
+    )
+    conn.commit()
+
