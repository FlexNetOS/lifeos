+    decision = control.approval_decision(
+        approval_id=gated_op["approval_id"],
+        decision="approved",
+        actor=operator_actor,
+        reason="integration verifier may project the approved plugin surface",
+        idempotency_key="REQ-041/approve-status-refresh",
+    )
