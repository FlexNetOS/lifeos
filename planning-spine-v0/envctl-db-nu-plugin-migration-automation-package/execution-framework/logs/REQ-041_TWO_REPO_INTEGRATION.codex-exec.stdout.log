+            "event_type": row["event_type"],
+            "phase": row["phase"],
+            "actor_type": row["actor_type"],
+            "actor_id": row["actor_id"],
+            "operation_id": row["operation_id"],
+            "timestamp_utc": row["created_at_utc"],
