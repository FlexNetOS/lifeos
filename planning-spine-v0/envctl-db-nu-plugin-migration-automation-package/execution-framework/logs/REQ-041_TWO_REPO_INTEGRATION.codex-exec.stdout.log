+        (run_id,),
+    ).fetchall()
+    records["EvidenceRecord"] = [
+        {
+            "evidence_id": row["id"],
+            "run_id": row["run_id"],
+            "operation_id": row["operation_id"],
+            "uri": row["uri"],
+            "evidence_kind": row["evidence_kind"],
+            "sha256": row["sha256"].removeprefix("sha256:"),
+            "redacted": bool(row["redacted"]),
+            "metadata": json_or_default(row["metadata_json"], {}),
