+        ("recipe-req022",),
+    )
+    run_row = fetch_one(
+        conn,
+        """
+        SELECT id, target_id, recipe_id, artifact_contract_id, status, human_mode, reproducibility_hash,
+               started_at_utc, completed_at_utc
+        FROM envctl_migration_runs
+        WHERE id = ?
+        """,
