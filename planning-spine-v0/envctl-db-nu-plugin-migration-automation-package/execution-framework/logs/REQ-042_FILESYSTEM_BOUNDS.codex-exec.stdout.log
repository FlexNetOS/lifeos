+        "title": "envctl Background Helper Filesystem Boundaries",
+        "type": "object",
+        "required": [
+            "schema_version",
+            "task_id",
+            "scope",
+            "allowed_paths",
+            "blocked_paths",
+            "safe_workspaces",
+            "rules",
+        ],
+        "properties": {
+            "schema_version": {"type": "string"},
+            "task_id": {"type": "string"},
+            "scope": {"type": "string"},
+            "repo_path": {"type": "string"},
+            "allowed_paths": {
+                "type": "array",
+                "items": {"$ref": "#/$defs/pathRule"},
+                "minItems": 1,
+            },
+            "blocked_paths": {
+                "type": "array",
+                "items": {"$ref": "#/$defs/pathRule"},
+                "minItems": 1,
+            },
+            "safe_workspaces": {
+                "type": "array",
+                "items": {"$ref": "#/$defs/workspace"},
+                "minItems": 1,
+            },
+            "rules": {
+                "type": "array",
+                "items": {"type": "string", "minLength": 1},
+                "minItems": 1,
