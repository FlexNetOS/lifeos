+            },
+            {
+                "id": "execution_templates",
+                "pattern": "execution-templates/**",
+                "mode": "allow",
+                "env_var": None,
+                "description": "package-local reusable execution templates.",
+            },
+        ],
+        "blocked_paths": [
+            {
+                "id": "dot_env_files",
+                "pattern": "**/.env",
+                "mode": "block",
