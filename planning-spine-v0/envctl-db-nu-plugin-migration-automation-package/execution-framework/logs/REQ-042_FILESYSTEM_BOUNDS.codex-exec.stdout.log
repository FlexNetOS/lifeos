+                    "path": {"type": "string", "minLength": 1},
+                    "purpose": {"type": "string", "minLength": 1},
+                    "write_policy": {"type": "string", "minLength": 1},
+                    "retention": {"type": "string"},
+                },
+                "additionalProperties": True,
+            },
+        },
+        "additionalProperties": True,
+    }
+
+
