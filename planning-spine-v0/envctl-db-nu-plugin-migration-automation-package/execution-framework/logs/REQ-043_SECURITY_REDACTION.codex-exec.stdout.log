+REPRODUCIBILITY_IDENTITY_FIELDS = [
+    "target_descriptor_hash",
+    "artifact_contract_hash",
+    "recipe_hash",
+    "package_hashes",
+    "collector_versions",
+    "tool_versions",
+    "operation_input_hashes",
