+            "task_id": TASK_ID,
+            "redacted": True,
+        },
+    )
+
+    fixture_failures = [item for item in fixture_results if item["status"] != "pass"]
+    blocked_failures = [item for item in blocked_results if not item["blocked"]]
+    status = (
