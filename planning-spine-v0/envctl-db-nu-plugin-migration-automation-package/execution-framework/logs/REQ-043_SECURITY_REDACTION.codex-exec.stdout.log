+)
+
+
+TASK_ID = "REQ-043_SECURITY_REDACTION"
+HELPER_ID = "helper-security-01"
+MODEL_TAG = "gpt-5.3-spark"
+
+GENERATED_FILES = [
+    "execution-framework/scripts/redaction_controls.py",
