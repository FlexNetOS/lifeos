            f"- Blocked path probes passed: `{report['blocked_path_probe_count']}`",
            f"- Chain hash sample: `{report['chain_hash_sample']}`",
        ]
    )
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text("\n".join(lines) + "\n", encoding="utf-8")

