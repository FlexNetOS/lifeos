+            r"authorization|bearer)\b\s*[:=]\s*(\"[^\"]+\"|'[^']+'|[^\s,}]+)"
+        ),
+    },
+    {
+        "id": "aws-access-key-id-assignment",
+        "regex": r"(?i)\baws_access_key_id\s*=\s*[A-Z0-9]{16,}",
