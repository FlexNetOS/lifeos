+    "execution-framework/proof_records/proof_ledger.jsonl",
+]
+
+
+def redaction_fixtures() -> list[dict[str, object]]:
+    return [
+        {
+            "name": "generic-api-key",
+            "input": {"command": "tool --set <REDACTED:SECRET>},
+            "blocked_fragments": ["example-secret-value"],
+        },
+        {
+            "name": "bearer-header",
