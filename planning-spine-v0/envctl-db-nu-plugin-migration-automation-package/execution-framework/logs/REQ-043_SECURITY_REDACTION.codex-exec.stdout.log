+        },
+    ]
+
+
+def verify_fixtures() -> list[dict[str, object]]:
+    results = []
+    for fixture in redaction_fixtures():
+        redacted = redact_value(fixture["input"])
+        rendered = json.dumps(redacted, sort_keys=True)
+        leaks = [
+            fragment
