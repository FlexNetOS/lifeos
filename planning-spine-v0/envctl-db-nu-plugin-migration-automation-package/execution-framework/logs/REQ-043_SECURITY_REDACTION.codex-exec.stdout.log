+    lines.extend(
+        [
+            "",
+            "## Reproducibility Identity",
+            "",
+        ]
+    )
+    lines.extend(f"- `{field}`" for field in manifest["reproducibility_identity_fields"])
+    lines.extend(
+        [
+            "",
+            "## Replay Modes",
+            "",
+            "| mode | behavior |",
+            "|---|---|",
