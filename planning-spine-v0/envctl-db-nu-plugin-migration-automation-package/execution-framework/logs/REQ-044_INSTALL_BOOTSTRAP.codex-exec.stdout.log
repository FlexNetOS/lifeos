+    nu_plugin = "${NU_PLUGIN_REPO:?set NU_PLUGIN_REPO}"
+    flexnetos = "${FLEXNETOS_PACKAGE:-$PROMPT_PACKAGE_DIR/source/codex-flexnetos-migration-prompt-package}"
