+        "argv": command,
+        "shell": "bash",
+        "purpose": purpose,
+        "requires": ["codex", "python3", "bash"],
+        "blocked_inputs": ["**/.env", "**/secrets/**", "**/private_keys/**", "**/*.pem", "**/*.key"],
+    }
+
+
