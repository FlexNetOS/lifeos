+            command_template(
+                "run-single-execution-packet",
+                "Run one bounded execution packet",
+                f"{pkg}/execution-framework",
+                ["codex", "exec", "<", packet],
+                "Execute a single generated packet and require its proof record before advancing dependent tasks.",
+            ),
+            command_template(
