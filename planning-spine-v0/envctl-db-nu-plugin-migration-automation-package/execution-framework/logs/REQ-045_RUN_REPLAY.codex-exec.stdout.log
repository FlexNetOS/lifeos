+        root() / "docs" / "ENVCTL_REPLAY_ENGINE.md",
+        root() / "docs" / "ENVCTL_ROLLBACK_CHECKPOINTS.md",
+        root() / "docs" / "INSTALL_BOOTSTRAP.md",
