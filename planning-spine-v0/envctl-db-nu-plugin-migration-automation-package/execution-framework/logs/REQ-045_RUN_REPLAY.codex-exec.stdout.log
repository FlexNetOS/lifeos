+        },
+        "command_template_ids": ids,
+        "convenience_templates_present": [item["path"] for item in manifest["convenience_templates"]],
+        "errors": errors,
+        "evidence": evidence,
+    }
+
+
+def main() -> int:
+    started_at = now()
+    manifest = build_manifest()
+    write_json("generated/run_replay_manifest.json", manifest)
