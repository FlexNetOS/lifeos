+        argv = template.get("argv") or []
+        if not argv:
+            errors.append(f"{template['command_id']} has no argv template")
+            continue
+        joined = " ".join(argv)
+        for blocked in template.get("blocked_inputs", []):
+            token = blocked.replace("**/", "")
+            if token in joined:
