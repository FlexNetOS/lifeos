+    checks["no_blocked_secret_paths_in_generated_evidence"] = not blocked_evidence_hits
+    status = "pass" if all(checks.values()) else "fail"
+    return {
+        "schema_version": "1.0",
+        "task_id": TASK_ID,
+        "generated_at": utc_now(),
