+
+BLOCKED_PARTS = {".git", ".env", "secrets", "private_keys", ".venv", "__pycache__", "node_modules", "target"}
+BLOCKED_SUFFIXES = {".pem", ".key"}
+FORBIDDEN_TEXT_MARKERS = ("/secrets/", "/private_keys/")
