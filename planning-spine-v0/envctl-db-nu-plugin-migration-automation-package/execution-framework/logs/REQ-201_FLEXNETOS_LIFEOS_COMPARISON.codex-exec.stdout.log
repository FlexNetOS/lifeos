+    repositories = repo_map.get("repositories", [])
+    lifeos_repo = find_repository(repositories, "src/lifeos")
+    catalog_path = PRIMARY_ROOT / "src" / "flexnetos_runner" / "release" / "catalog.tsv"
+    catalog = release_catalog_rows(catalog_path)
