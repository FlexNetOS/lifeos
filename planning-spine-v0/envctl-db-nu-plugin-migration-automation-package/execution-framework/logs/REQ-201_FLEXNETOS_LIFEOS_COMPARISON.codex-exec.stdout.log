+
+    files_changed = [ARTIFACT_JSON, ARTIFACT_MD, VALIDATION_PATH, HEARTBEAT_PATH, LOG_PATH, PROOF_PATH]
+    checksums = {rel_workspace(path): sha256(path) for path in files_changed if path.exists() and path != PROOF_PATH}
+    proof = {
