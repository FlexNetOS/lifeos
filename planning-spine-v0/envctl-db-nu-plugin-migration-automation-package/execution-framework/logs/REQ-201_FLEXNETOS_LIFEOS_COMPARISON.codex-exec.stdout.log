+        block = [f"### {name}"]
+        if not entries:
+            block.append("- No line evidence found.")
+            return block
+        for entry in entries:
+            text = str(entry["text"]).replace("|", "\\|")
+            block.append(f"- L{entry['line']}: `{text}`")
