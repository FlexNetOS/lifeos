+                            "recipe_id": "flexnetos-codex-package-target-adapter",
+                        },
+                        "expected_artifacts": [
+                            "recipe-registry-row",
+                        ],
+                        "validators": [
+                            "stable_recipe_id",
+                            "target_descriptor_reference_present",
+                        ],
+                        "rollback": {
