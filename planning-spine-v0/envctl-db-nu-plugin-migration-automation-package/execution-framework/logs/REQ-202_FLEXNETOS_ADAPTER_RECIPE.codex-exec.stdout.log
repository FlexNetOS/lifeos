+                        "operation_type": "recipe.validate",
+                        "risk": "R2",
+                        "inputs": {
+                            "verification_command": "python3 scripts/verify_flexnetos_adapter_recipe.py",
+                        },
+                        "expected_artifacts": [
+                            "flexnetos-adapter-validation-report",
+                        ],
+                        "validators": [
+                            "validation_report_passed",
+                            "no_secret_exposure",
+                        ],
+                        "rollback": {
