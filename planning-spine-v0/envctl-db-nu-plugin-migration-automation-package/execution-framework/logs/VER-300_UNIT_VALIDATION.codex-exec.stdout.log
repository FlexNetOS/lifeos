+            {
+                "schema_version": "1.0",
+                "task_id": TASK_ID,
+                "status": report["status"],
+                "updated_at": generated_at,
+                "proof_uri": PROOF_PATH,
+                "validation_report": REPORT_PATH,
+            },
+        )
+
+    files_changed = [
+        "execution-framework/scripts/verify_ver300_unit_validation.py",
