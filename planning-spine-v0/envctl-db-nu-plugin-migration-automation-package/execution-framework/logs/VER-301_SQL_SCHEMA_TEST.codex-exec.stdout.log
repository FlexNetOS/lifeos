def sqlite_objects(conn: sqlite3.Connection, kind: str) -> list[str]:
    return [
        row[0]
        for row in conn.execute(
            """
            SELECT name
            FROM sqlite_master
            WHERE type = ? AND name LIKE 'envctl_migration_%'
            ORDER BY name
            """,
            (kind,),
        )
    ]


