+                )
+                if fixture_errors:
+                    errors.append(f"gap report failed schema validation: {GAP_REPORT_PATH}")
+            elif relpath == "schemas/proof_record.schema.json":
+                proof_template = read_json(PROOF_TEMPLATE_PATH)
