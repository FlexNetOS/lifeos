    "task_id": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "started_at": {
      "type": "string"
    },
    "completed_at": {
      "type": "string"
    },
    "actor": {
      "type": "string"
    },
    "helper_id": {
      "type": "string"
    },
    "model_tag": {
      "type": "string"
    },
    "repo_path": {
      "type": "string"
    },
    "files_changed": {
