    "task_id",
    "status",
    "started_at",
    "completed_at",
    "actor",
    "helper_id",
    "model_tag",
    "repo_path",
    "files_changed",
    "commands_run",
    "verification_output",
    "checksums",
    "logs_uri",
    "rollback_point",
    "evidence",
    "failure_reason",
    "next_action"
