{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "envctl Migration Artifact Record",
  "type": "object",
  "required": [
    "artifact_id",
    "run_id",
    "title",
    "status"
  ],
  "properties": {
    "artifact_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "enum": [
        "complete",
        "partial",
        "unknown",
        "blocked"
      ]
    },
    "artifact_type": {
      "type": "string"
    },
    "path": {
      "type": [
        "string",
        "null"
      ]
    },
    "content_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "to",
          "type"
        ],
        "properties": {
          "to": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        }
      }
    }
  }
}
