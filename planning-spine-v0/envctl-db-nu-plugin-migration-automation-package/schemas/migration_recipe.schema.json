{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "envctl Migration Recipe",
  "type": "object",
  "required": [
    "schema_version",
    "recipe_id",
    "version",
    "phases"
  ],
  "properties": {
    "schema_version": {
      "type": "integer"
    },
    "recipe_id": {
      "type": "string"
    },
    "version": {
      "type": [
        "integer",
        "string"
      ]
    },
    "phases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/phase"
      }
    },
    "metadata": {
      "type": "object"
    }
  },
  "$defs": {
    "phase": {
      "type": "object",
      "required": [
        "phase_id",
        "operations"
      ],
      "properties": {
        "phase_id": {
          "type": "string"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "approval_gate": {
          "type": "boolean"
        },
        "operations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/operation"
          }
        }
      }
    },
    "operation": {
      "type": "object",
      "required": [
        "operation_id",
        "operation_type",
        "risk"
      ],
      "properties": {
        "operation_id": {
          "type": "string"
        },
        "operation_type": {
          "type": "string"
        },
        "risk": {
          "enum": [
            "R0",
            "R1",
            "R2",
            "R3",
            "R4",
            "R5"
          ]
        },
        "inputs": {
          "type": "object"
        },
        "expected_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "validators": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rollback": {
          "type": [
            "object",
            "null"
          ]
        }
      }
    }
  }
}
