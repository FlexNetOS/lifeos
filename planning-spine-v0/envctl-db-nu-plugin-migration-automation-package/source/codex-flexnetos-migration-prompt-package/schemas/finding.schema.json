{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low",
        "unknown"
      ]
    },
    "evidence": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "finding": {
      "type": "string"
    },
    "unknowns": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "finding",
    "confidence",
    "evidence",
    "unknowns"
  ],
  "type": "object"
}
