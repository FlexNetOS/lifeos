{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lifeos.local/navigation/schemas/navigation-graph.schema.json",
  "title": "LifeOS Planning Spine Navigation Graph",
  "description": "Deterministic typed graph over planning-spine files and semantic planning entities.",
  "type": "object",
  "required": ["schema_version", "id", "title", "description", "source", "root_node_id", "nodes", "edges"],
  "properties": {
    "schema_version": { "const": "lifeos-planning-spine.navigation-graph.v0" },
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "source": {
      "type": "object",
      "required": ["path", "sha256", "inventory_sha256", "deterministic", "generated_at"],
      "properties": {
        "path": { "type": "string" },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "inventory_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "deterministic": { "const": true },
        "generated_at": { "type": "null" }
      },
      "additionalProperties": false
    },
    "root_node_id": { "type": "string", "minLength": 1 },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind", "title", "description", "path", "status", "authority_class", "lifecycle", "aliases", "tags", "identifiers", "headings", "routes", "content", "metadata", "relations"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "path": { "type": ["string", "null"] },
          "status": { "type": "string", "minLength": 1 },
          "authority_class": { "type": "string", "minLength": 1 },
          "lifecycle": { "type": "string", "minLength": 1 },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "tags": { "type": "array", "items": { "type": "string" } },
          "identifiers": { "type": "array", "items": { "type": "string" } },
          "headings": { "type": "array", "items": { "type": "string" } },
          "routes": { "type": "array", "items": { "type": "string" } },
          "content": { "type": ["object", "null"] },
          "metadata": { "type": "object" },
          "relations": {
            "type": "object",
            "required": ["incoming", "outgoing"],
            "properties": {
              "incoming": { "type": "integer", "minimum": 0 },
              "outgoing": { "type": "integer", "minimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "kind"],
        "properties": {
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "detail": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
