{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lifeos.local/navigation/schemas/navigation-index.schema.json",
  "title": "LifeOS Planning Spine Navigation Index",
  "description": "Compact exact-lookup and search-record projection of the navigation graph; typed neighbors remain in the graph artifact.",
  "type": "object",
  "required": ["schema_version", "id", "title", "description", "source", "entrypoints", "records", "by_path", "by_kind", "by_task_id", "by_work_order_id", "by_mandatory_capability_id", "by_claim_id", "by_source_id", "by_alias", "by_tag", "by_route"],
  "properties": {
    "schema_version": { "const": "lifeos-planning-spine.navigation-index.v0" },
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "source": { "type": "object" },
    "entrypoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "node_id"],
        "properties": {
          "path": { "type": "string" },
          "node_id": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "records": { "type": "object", "minProperties": 1, "additionalProperties": { "$ref": "#/$defs/record" } },
    "by_path": { "$ref": "#/$defs/pathLookup" },
    "by_kind": { "$ref": "#/$defs/listLookup" },
    "by_task_id": { "$ref": "#/$defs/pathLookup" },
    "by_work_order_id": { "$ref": "#/$defs/workOrderLookup" },
    "by_mandatory_capability_id": { "$ref": "#/$defs/mandatoryCapabilityLookup" },
    "by_claim_id": { "$ref": "#/$defs/pathLookup" },
    "by_source_id": { "$ref": "#/$defs/pathLookup" },
    "by_alias": { "$ref": "#/$defs/listLookup" },
    "by_tag": { "$ref": "#/$defs/listLookup" },
    "by_route": { "$ref": "#/$defs/listLookup" }
  },
  "$defs": {
    "record": {
      "type": "object",
      "required": ["title", "description", "kind", "path", "status", "authority_class", "lifecycle", "aliases", "tags", "identifiers", "headings", "routes"],
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "kind": { "type": "string" },
        "path": { "type": ["string", "null"] },
        "status": { "type": "string" },
        "authority_class": { "type": "string" },
        "lifecycle": { "type": "string" },
        "aliases": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "identifiers": { "type": "array", "items": { "type": "string" } },
        "headings": { "type": "array", "items": { "type": "string" } },
        "routes": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "pathLookup": { "type": "object", "additionalProperties": { "type": "string" } },
    "workOrderLookup": {
      "type": "object",
      "minProperties": 106,
      "maxProperties": 106,
      "propertyNames": { "pattern": "^TASK-CDB[0-9]{3}$" },
      "additionalProperties": { "type": "string", "pattern": "^structured:imported-work-order:task-cdb[0-9]{3}$" }
    },
    "mandatoryCapabilityLookup": {
      "type": "object",
      "minProperties": 26,
      "maxProperties": 26,
      "propertyNames": { "pattern": "^CAP-MIG-[0-9]{3}$" },
      "additionalProperties": { "type": "string", "pattern": "^structured:mandatory-migration-capability:cap-mig-[0-9]{3}$" }
    },
    "listLookup": {
      "type": "object",
      "additionalProperties": { "type": "array", "items": { "type": "string" } }
    }
  },
  "additionalProperties": false
}
