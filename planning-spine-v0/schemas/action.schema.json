{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lifeos.dev/planning-spine/v0/schemas/action.schema.json",
  "title": "Action",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "task_id",
    "action_type",
    "description",
    "actor_id",
    "preconditions",
    "expected_artifacts",
    "verification_gate",
    "status"
  ],
  "properties": {
    "id": { "type": "string" },
    "task_id": { "type": "string" },
    "action_type": { "type": "string" },
    "description": { "type": "string" },
    "actor_id": { "type": "string" },
    "preconditions": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "expected_artifacts": { "type": "array", "items": { "type": "string" } },
    "verification_gate": { "type": "string" },
    "status": { "type": "string", "enum": ["pending", "ready", "running", "complete", "blocked"] }
  }
}
