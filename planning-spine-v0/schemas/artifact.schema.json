{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lifeos.dev/planning-spine/v0/schemas/artifact.schema.json",
  "title": "Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "task_id",
    "artifact_type",
    "uri",
    "content_hash",
    "generated_by",
    "verification_status",
    "proof_record_ids"
  ],
  "properties": {
    "id": { "type": "string" },
    "task_id": { "type": "string" },
    "artifact_type": { "type": "string" },
    "uri": { "type": "string" },
    "content_hash": { "type": "string" },
    "generated_by": { "type": "string" },
    "verification_status": { "type": "string", "enum": ["pending", "pass", "fail"] },
    "proof_record_ids": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
  }
}
