{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lifeos.dev/planning-spine/v0/schemas/goal.schema.json",
  "title": "Goal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "intent_id",
    "title",
    "desired_outcome",
    "authority_scope",
    "priority",
    "status",
    "task_ids",
    "proof_uri"
  ],
  "properties": {
    "id": { "type": "string" },
    "intent_id": { "type": "string" },
    "title": { "type": "string" },
    "desired_outcome": { "type": "string" },
    "authority_scope": { "type": "string" },
    "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "status": { "type": "string", "enum": ["draft", "active", "complete", "blocked"] },
    "task_ids": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "proof_uri": { "type": "string" }
  }
}
