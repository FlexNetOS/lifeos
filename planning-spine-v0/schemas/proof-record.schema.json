{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lifeos.dev/planning-spine/v0/schemas/proof-record.schema.json",
  "title": "ProofRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "subject_type",
    "subject_id",
    "proof_kind",
    "uri",
    "hash",
    "verified_by",
    "verified_at",
    "result"
  ],
  "properties": {
    "id": { "type": "string" },
    "subject_type": { "type": "string", "enum": ["task", "artifact", "decision", "action"] },
    "subject_id": { "type": "string" },
    "proof_kind": { "type": "string" },
    "uri": { "type": "string" },
    "hash": { "type": "string" },
    "verified_by": { "type": "string" },
    "verified_at": { "type": "string" },
    "result": { "type": "string", "enum": ["pass", "fail"] }
  }
}
